PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

SELECT DISTINCT ?altNameClone8 ?fullNameClone8 r?ecNameClone8 ?shortNameClone8
WHERE {

    ?entryClone8 up:recommendedName ?recNameClone8.
    ?entryClone8 up:alternativeName ?altNameClone8.
    ?recNameClone8 up:fullName ?fullNameClone8.
    ?recNameClone8 up:shortName ?shortNameClone8.
    
}

