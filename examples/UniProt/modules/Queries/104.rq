PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

SELECT (COUNT(?entryClone7) AS ?truc)
WHERE {

    ?entryClone7 up:recommendedName ?recNameClone7.
    #?entryClone7 up:alternativeName ?altNameClone7.
    ?recNameClone7 up:fullName ?fullNameClone7.
    #?recNameClone7 up:shortName ?shortNameClone7.
    
}
