PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>
SELECT DISTINCT ?creationDateClone26 ?modificationDateClone26 ?proteinClone26 ?reviewedClone26 ?versionClone26
WHERE {

    ?proteinClone26 rdf:type up:Protein ;
      up:created ?creationDateClone26 ;
      up:modified ?modificationDateClone26 ;
      up:reviewed ?reviewedClone26 ;
      up:version ?versionClone26 .
    
}
