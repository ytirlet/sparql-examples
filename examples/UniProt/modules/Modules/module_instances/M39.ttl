@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix rh: <http://rdf.rhea-db.org/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:M39_module a smodule:SPARQLModule ;
  rdfs:label "Protein to catalyzed reaction"@en;
  rdfs:comment "Protein to catalyzed reaction"@en;
  schema:keywords "catalytic activity", "catalyzed reaction";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
    """ ;
  smodule:fragmentSPARQL """
    ?protein rdf:type up:Protein .
    ?protein up:annotation ?annotation.
    ?annotation up:catalyticActivity ?catalyticActivity.
    ?catalyticActivity rdf:type up:Catalytic_Activity .
    ?catalyticActivity up:catalyzedReaction ?reaction.
    ?annotation rdf:type up:Catalytic_Activity_Annotation.
    """;
  smodule:output up_mod:M39_module_port-reaction, up_mod:M39_module_port-protein, up_mod:M39_module_port-annotation, up_mod:M39_module_port-catalyticActivity .

up_mod:M39_module_port-reaction
  a smodule:ModulePortURI;
  rdfs:domain rh:Reaction ;
  smodule:variableName "?reaction" ;
  rdfs:label "Reaction" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M39_module_port-annotation
  a smodule:ModulePortURI;
  smodule:variableName "?annotation" ;
  rdfs:domain up:Catalytic_Activity_Annotation ;
  rdfs:label "Annotation" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M39_module_port-protein
  a smodule:ModulePortURI;
  smodule:variableName "?protein" ;
  rdfs:domain up:Protein ;
  rdfs:label "Protein" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M39_module_port-catalyticActivity
  a smodule:ModulePortURI;
  smodule:variableName "?catalyticActivity" ;
  rdfs:domain up:Catalytic_Activity ;
  rdfs:label "Catalytic Activity" ;
  smodule:isSelected "true"^^xsd:boolean.
