@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

up_mod:M57_module a smodule:SPARQLModule ;
  rdfs:label "entry mnemonic"@en ;
  rdfs:comment "entry mnemonic"@en ;
  schema:keywords "mnemonic" ;
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
    """ ;
  smodule:fragmentSPARQL """
    ?entry rdf:type ?type.
    ?entry up:mnemonic ?mnemonic.
    OPTIONAL {?entry up:oldMnemonic ?oldmnemonic.}
    """ ;
  smodule:output up_mod:M57_module_port-entry, up_mod:M57_module_port-type, up_mod:M57_module_port-mnemonic, up_mod:M57_module_port-oldmnemonic .
    
up_mod:M57_module_port-entry
  a smodule:ModulePortURI ; 
  smodule:variableName "?entry" ; 
  rdfs:domain [
    a owl:Class ;
    smodule:option (up:Cluster up:Protein up:Sequence)
    ]; 
  rdfs:label "Entry" ;
  smodule:isSelected "true"^^xsd:boolean.
	
up_mod:M57_module_port-type
  a smodule:ModulePortURI ; 
  smodule:variableName "?type" ;
  smodule:option (up:Cluster up:Protein up:Sequence) ;
  rdfs:label "Entry type" ;
  smodule:isSelected "true"^^xsd:boolean.
	
up_mod:M57_module_port-mnemonic
  a smodule:ModulePortDatatype ; 
  smodule:variableName "?mnemonic" ;
  rdfs:domain xsd:string ;
  smodule:example "A4_HUMAN", "1433E_MOUSE", "1FEH2_WHEAT" ;
  rdfs:label "Mnemonic" ;
  smodule:isSelected "true"^^xsd:boolean.
	
up_mod:M57_module_port-oldmnemonic 
  a smodule:ModulePortDatatype ;
  smodule:variableName "?oldmnemonic" ;
  rdfs:domain xsd:string ;
  rdfs:label "Old mnemonic" ;
  smodule:isSelected "true"^^xsd:boolean.
