@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:M73_module a smodule:SPARQLModule;
  rdfs:label "protein to gene"@en;
  rdfs:comment "protein to gene"@en;
  schema:keywords "gene name";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
    PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
    """ ;
  smodule:fragmentSPARQL """
    ?protein rdf:type up:Protein.
    ?protein up:encodedBy ?gene.
    ?gene skos:prefLabel ?name.
    OPTIONAL {?gene up:locusName ?locusName.}
    OPTIONAL {?gene skos:altLabel ?altLabel.}
    OPTIONAL {?gene up:orfName ?orfName.}
    """;
  smodule:output up_mod:M73_module_port-protein, up_mod:M73_module_port-gene, up_mod:M73_module_port-name, up_mod:M73_module_port-locusName, up_mod:M73_module_port-altLabel, up_mod:M73_module_port-orfName.

up_mod:M73_module_port-name
  a smodule:ModulePortDatatype;
  rdfs:domain xsd:string ;
  smodule:variableName "?name" ;
  rdfs:label "Gene Name".

up_mod:M73_module_port-protein
  a smodule:ModulePortURI;
  rdfs:domain <http://purl.uniprot.org/core/Protein>;
  smodule:variableName "?protein" ;
  rdfs:label "Protein" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M73_module_port-gene
  a smodule:ModulePortURI;
  rdfs:domain up:Gene ;
  smodule:variableName "?gene" ;
  rdfs:label "Gene" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M73_module_port-locusName
  a smodule:ModulePortDatatype;
  rdfs:domain xsd:string ;
  smodule:variableName "?locusName" ;
  rdfs:label "Locus name" ;
  smodule:isSelected "true"^^xsd:boolean.
  
up_mod:M73_module_port-altLabel
  a smodule:ModulePortDatatype;
  rdfs:domain xsd:string ;
  smodule:variableName "?altLabel" ;
  rdfs:label "Alternative label" ;
  smodule:isSelected "true"^^xsd:boolean.  
  
up_mod:M73_module_port-orfName
  a smodule:ModulePortDatatype;
  rdfs:domain xsd:string ;
  smodule:variableName "?orfName" ;
  rdfs:label "ORF name" ;
  smodule:isSelected "true"^^xsd:boolean.
