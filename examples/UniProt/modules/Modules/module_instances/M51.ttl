@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:M51_module a smodule:SPARQLModule ;
  rdfs:label "protein and associated disease"@en;
  rdfs:comment "protein and associated disease"@en;
  schema:keywords "protein annotation", "disease";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
    PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
    """ ;
  smodule:fragmentSPARQL """
    ?protein up:annotation ?annotation.
    ?protein rdf:type up:Protein.
    ?annotation rdf:type up:Disease_Annotation.
    ?annotation up:disease ?disease.
    ?disease skos:prefLabel ?diseaseLabel.
    ?disease rdf:type up:Disease.
    """;
  smodule:output up_mod:M51_module_port-protein, up_mod:M51_module_port-annotation, up_mod:M51_module_port-disease, up_mod:M51_module_port-diseaseLabel .
  

up_mod:M51_module_port-annotation
  a smodule:ModulePortURI;
  smodule:variableName "?annotation" ;
  rdfs:domain up:Disease_Annotation ;
  rdfs:label "Annotation" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M51_module_port-disease
  a smodule:ModulePortURI;
  smodule:variableName "?disease" ;
  rdfs:label "Disease" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M51_module_port-protein
  a smodule:ModulePortURI;
  rdfs:domain up:Protein;
  smodule:variableName "?protein" ;
  rdfs:label "Protein" ;
  smodule:isSelected "true"^^xsd:boolean.
  
up_mod:M51_module_port-diseaseLabel
  a smodule:ModulePortDatatype;
  rdfs:domain xsd:string;
  smodule:variableName "?diseaseLabel" ;
  rdfs:label "Disease label" ;
  smodule:isSelected "true"^^xsd:boolean.
