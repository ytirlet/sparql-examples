@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:M40_module a smodule:SPARQLModule;
  rdfs:label "Protein to annotation range"@en;
  rdfs:comment "Protein to annotation range"@en;
  schema:keywords "protein annotation", "annotation range";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
    """ ;
  smodule:fragmentSPARQL """
    ?protein up:annotation ?annotation.
    ?annotation up:range ?range.
    """;
  smodule:output up_mod:M40_module_port-protein, up_mod:M40_module_port-annotation, up_mod:M40_module_port-range .

up_mod:M40_module_port-annotation
  a smodule:ModulePortURI;
  rdfs:domain up:Annotation ;
  smodule:variableName "?annotation" ;
  rdfs:label "Annotation" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M40_module_port-protein
  a smodule:ModulePortURI;
  smodule:variableName "?protein" ;
  rdfs:domain up:Protein ;
  rdfs:label "Protein" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M40_module_port-range
  a smodule:ModulePortURI;
  smodule:variableName "?range" ;
  rdfs:label "Range" ;
  smodule:isSelected "true"^^xsd:boolean.
