@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:M84_module a smodule:SPARQLModule;
  rdfs:label "Enzyme class"@en;
  rdfs:comment "Enzyme class"@en;
  schema:keywords "EC";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  """ ;
  smodule:fragmentSPARQL """ 
    ?catalyticActivity up:enzymeClass ?EC .
    ?EC rdfs:subClassOf ?ancestorEC.
    """;
  smodule:output up_mod:M84_module_port-catalyticActivity, up_mod:M84_module_port-EC, up_mod:M84_module_port-ancestorEC.
  
up_mod:M84_module_port-EC
  a smodule:ModulePortURI;
  rdfs:domain up:Enzyme ;
  smodule:variableName "?EC" ;
  rdfs:label "Enzyme" ;
  smodule:isSelected "true"^^xsd:boolean .

up_mod:M84_module_port-ancestorEC
  a smodule:ModulePortURI;
  rdfs:domain up:Enzyme ;
  smodule:variableName "?ancestorEC" ;
  rdfs:label "ancestor Enzyme" ;
  smodule:isSelected "true"^^xsd:boolean .

up_mod:M84_module_port-catalyticActivity
  a smodule:ModulePortURI;
  rdfs:domain up:CatalyticActivity;
  smodule:variableName "?catalyticActivity" ;
  rdfs:label "Catalytic Activity" ;
  smodule:isSelected "true"^^xsd:boolean .
