@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:M45_module a smodule:SPARQLModule ;
  rdfs:label "protein transcribed from gene"@en;
  rdfs:comment "protein transcribed from gene"@en;
  schema:keywords "transcribed from";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
    """ ;
  smodule:fragmentSPARQL """
    ?protein rdfs:seeAlso ?entry.
    ?entry up:transcribedFrom ?gene.
    """;
  smodule:output up_mod:M45_module_port-protein, up_mod:M45_module_port-entry, up_mod:M45_module_port-gene .

up_mod:M45_module_port-entry
  a smodule:ModulePortURI;
  rdfs:domain xsd:anyURI ;
  smodule:variableName "?entry" ;
  rdfs:label "see also entry" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M45_module_port-protein
  a smodule:ModulePortURI;
  smodule:variableName "?protein" ;
  rdfs:domain up:Protein ;
  rdfs:label "Protein" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M45_module_port-gene
  a smodule:ModulePortURI;
  rdfs:domain up:Gene;
  smodule:variableName "?gene" ;
  rdfs:label "Gene" ;
  smodule:isSelected "true"^^xsd:boolean.
