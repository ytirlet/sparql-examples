@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

up_mod:M95_module a smodule:SPARQLModule;
  rdfs:label "Sequence fragment"@en;
  rdfs:comment "Sequence fragment"@en;
  schema:keywords "fragment";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  """ ;
  smodule:fragmentSPARQL """ 
    ?sequence a up:Sequence.
    ?sequence up:fragment ?fragment .
    """;
  smodule:output up_mod:M95_module_port-sequence, up_mod:M95_module_port-fragment.
  
up_mod:M95_module_port-fragment
  a smodule:ModulePortDatatype;
  rdfs:domain [
    a owl:Class ;
    smodule:option ("multiple" "single")
    ]; 
  smodule:variableName "?fragment" ;
  rdfs:label "Fragment" ;
  smodule:isSelected "true"^^xsd:boolean .

up_mod:M95_module_port-sequence
  a smodule:ModulePortURI;
  rdfs:domain up:Sequence;
  smodule:variableName "?sequence" ;
  rdfs:label "Sequence" ;
  smodule:isSelected "true"^^xsd:boolean .
