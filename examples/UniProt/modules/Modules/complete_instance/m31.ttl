@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:m31_module a smodule:SPARQLModule;
  rdfs:label "Database protein"@en;
  rdfs:comment "Database protein"@en;
  schema:keywords "protein";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  """ ;
  smodule:fragmentSPARQL """ 
    BIND(SUBSTR(STR(?protein),33) AS ?accession)
  BIND(IF(CONTAINS(STR(?annotation), "#SIP"), SUBSTR(STR(?annotation),33), SUBSTR(STR(?annotation),36))AS?annotation_acc)
  BIND(SUBSTR(STR(?source),35) AS ?pubmed)
    """;
  smodule:output up_mod:m31_module_port-annotation, up_mod:m31_module_port-protein, up_mod:m31_module_port-source.
  
up_mod:m31_module_port-protein
  a smodule:ModulePortURI;
  rdfs:domain up:Protein ;
  smodule:variableName "?protein" ;
  rdfs:label "protein" ;
  smodule:isSelected "true"^^xsd:boolean .

up_mod:m31_module_port-annotation
  a smodule:ModulePortURI;
  rdfs:domain up:Annotation ;
  smodule:variableName "?annotation" ;
  rdfs:label "annotation" ;
  smodule:isSelected "true"^^xsd:boolean .
  
up_mod:m31_module_port-source
  a smodule:ModulePortURI;
  smodule:variableName "?source" ;
  rdfs:label "source" ;
  smodule:isSelected "true"^^xsd:boolean .
