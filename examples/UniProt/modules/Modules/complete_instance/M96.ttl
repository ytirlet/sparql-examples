@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:M96_module a smodule:SPARQLModule;
  rdfs:label "Database category"@en;
  rdfs:comment "Database category"@en;
  schema:keywords "category";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  """ ;
  smodule:fragmentSPARQL """ 
    ?database a up:database.
    ?database up:category ?category .
    """;
  smodule:output up_mod:M96_module_port-database, up_mod:M96_module_port-category.
  
up_mod:M96_module_port-category
  a smodule:ModulePortDatatype;
  rdfs:domain xsd:string ;
  smodule:variableName "?category" ;
  rdfs:label "Category" ;
  smodule:isSelected "true"^^xsd:boolean .

up_mod:M96_module_port-database
  a smodule:ModulePortURI;
  rdfs:domain up:Database;
  smodule:variableName "?database" ;
  rdfs:label "Database" ;
  smodule:isSelected "true"^^xsd:boolean .
