@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix rh: <http://rdf.rhea-db.org/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

up_mod:M37_module a smodule:SPARQLModule;
  rdfs:label "ChEBI restriction"@en;
  rdfs:comment "ChEBI restriction"@en;
  schema:keywords "ChEBI restriction";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
    PREFIX rh: <http://rdf.rhea-db.org/>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
    PREFIX owl: <http://www.w3.org/2002/07/owl#>
    PREFIX chebi: <http://purl.obolibrary.org/obo/CHEBI_>
    """ ;
  smodule:fragmentSPARQL """
    ?compound rh:chebi ?chebi.
    ?chebiRestriction owl:someValuesFrom ?chebi.
    ?chebiRestriction rdf:type owl:Restriction.
    ?chebi2 rdfs:subClassOf ?chebiRestriction.
    ?chebi2 (rdfs:subClassOf)+ ?chebiAncestor.
    """;
  smodule:output up_mod:M37_module_port-compound, up_mod:M37_module_port-chebi, up_mod:M37_module_port-chebiAncestor, up_mod:M37_module_port-chebiRestriction, up_mod:M37_module_port-chebi2 .

up_mod:M37_module_port-compound
  a smodule:ModulePortURI;
  rdfs:domain rh:Compound;
  smodule:variableName "?compound" ;
  rdfs:label "Compound" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M37_module_port-chebiRestriction
  a smodule:ModulePortURI;
  rdfs:domain owl:Restriction;
  smodule:variableName "?chebiRestriction" ;
  rdfs:label "ChEBI Restriction" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M37_module_port-chebi2
  a smodule:ModulePortURI;
  smodule:variableName "?chebi2" ;
  rdfs:label "ChEBI 2" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M37_module_port-chebi
  a smodule:ModulePortURI;
  smodule:variableName "?chebi" ;
  rdfs:label "ChEBI" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M37_module_port-chebiAncestor
  a smodule:ModulePortURI;
  smodule:variableName "?chebiAncestor" ;
  rdfs:label "Ancestor ChEBI" ;
  smodule:isSelected "true"^^xsd:boolean.
