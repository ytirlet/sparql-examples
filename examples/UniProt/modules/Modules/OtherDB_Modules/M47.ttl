@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix rh: <http://rdf.rhea-db.org/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:M47_module a smodule:SPARQLModule;
  rdfs:label "protein linked to reaction and compound"@en;
  rdfs:comment "protein linked to reaction and compound"@en;
  schema:keywords "catalyzed reaction", "catalytic activity";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
    PREFIX rh: <http://rdf.rhea-db.org/>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
    """ ;
  smodule:fragmentSPARQL """
    ?protein up:annotation ?annotation.
    ?annotation up:catalyticActivity ?catalyticActivity.
    ?catalyticActivity up:catalyzedReaction ?reaction.
    SERVICE <https://sparql.rhea-db.org/sparql> {
    	?reaction rdfs:subClassOf rh:Reaction.
    	?reaction rh:side ?side.
    	?side rh:contains ?participant.
    	?participant rh:compound ?compound.
    }
    """;
  smodule:output up_mod:M47_module_port-protein, up_mod:M47_module_port-annotation, up_mod:M47_module_port-reaction, up_mod:M47_module_port-compound .

up_mod:M47_module_port-reaction
  a smodule:ModulePortURI;
  smodule:variableName "?reaction" ;
  rdfs:domain rh:Reaction ;
  rdfs:label "Reaction" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M47_module_port-annotation
  a smodule:ModulePortURI;
  rdfs:domain up:Annotation ;
  smodule:variableName "?annotation" ;
  rdfs:label "Annotation" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M47_module_port-compound
  a smodule:ModulePortURI;
  rdfs:domain rh:Compound;
  smodule:variableName "?compound" ;
  rdfs:label "Compound" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M47_module_port-protein
  a smodule:ModulePortURI;
  smodule:variableName "?protein" ;
  rdfs:domain up:Protein ;
  rdfs:label "Protein" ;
  smodule:isSelected "true"^^xsd:boolean.

