@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:M94_module a smodule:SPARQLModule;
  rdfs:label "entry citation"@en;
  rdfs:comment "entry citation"@en;
  schema:keywords "citation";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  """ ;
  smodule:fragmentSPARQL """ 
    ?entry up:citation ?citation .
    ?citation a up:Journal_Citation ;
     dcterms:identifier ?doi .
    """;
  smodule:output up_mod:M94_module_port-entry, up_mod:M94_module_port-citation, up_mod:M94_module_port-doi.
  
up_mod:M94_module_port-citation
  a smodule:ModulePortURI;
  rdfs:domain up:Citation ;
  smodule:variableName "?citation" ;
  rdfs:label "Journal citation" ;
  smodule:isSelected "true"^^xsd:boolean .

up_mod:M94_module_port-entry
  a smodule:ModulePortURI;
  rdfs:domain up:entry;
  smodule:variableName "?entry" ;
  rdfs:label "entry" ;
  smodule:isSelected "true"^^xsd:boolean .

up_mod:M94_module_port-doi
  a smodule:ModulePortDatatype;
  rdfs:domain xsd:string ;
  smodule:variableName "?doi" ;
  rdfs:label "Citation DOI" ;
  smodule:isSelected "true"^^xsd:boolean .
