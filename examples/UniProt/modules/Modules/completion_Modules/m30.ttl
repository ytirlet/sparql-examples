@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:m30_module a smodule:SPARQLModule;
  rdfs:label "englishLabelStr structured name"@en;
  rdfs:comment "englishLabelStr structured name"@en;
  schema:keywords "structured name";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  """ ;
  smodule:fragmentSPARQL """ 
    BIND((CONCAT('chebi:',SUBSTR(STR(?chebi), STRLEN(STR(CHEBI:))+1))) AS ?chebiId)
    """;
  smodule:output up_mod:m30_module_port-chebi, up_mod:m30_module_port-chebId.
  
up_mod:m30_module_port-chebi
  a smodule:ModulePortURI ;
  smodule:variableName "?chebi";
  rdfs:domain xsd:anyURI ;
  rdfs:label "chebi" ;
  smodule:isSelected "true"^^xsd:boolean.
  
up_mod:m30_module_port-chebId
  a smodule:ModulePortURI ;
  smodule:variableName "?chebId";
  rdfs:domain xsd:anyURI ;
  rdfs:label "chebId" ;
  smodule:isSelected "true"^^xsd:boolean.
