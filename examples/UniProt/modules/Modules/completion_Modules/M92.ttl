@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

up_mod:M92_module a smodule:SPARQLModule;
  rdfs:label "Protein cluster identity"@en;
  rdfs:comment "Protein cluster identity"@en;
  schema:keywords "cluster";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  """ ;
  smodule:fragmentSPARQL """ 
    ?protein rdf:type up:Protein.
    ?protein up:seedFor ?cluster .
    ?cluster up:identity ?identity .
    """;
  smodule:output up_mod:M92_module_port-protein, up_mod:M92_module_port-cluster, up_mod:M92_module_port-identity .
  
up_mod:M92_module_port-cluster
  a smodule:ModulePortURI;
  rdfs:domain up:Cluster ;
  smodule:variableName "?cluster" ;
  rdfs:label "Cluster of proteins" ;
  smodule:isSelected "true"^^xsd:boolean .

up_mod:M92_module_port-protein
  a smodule:ModulePortURI;
  rdfs:domain up:Protein;
  smodule:variableName "?protein" ;
  rdfs:label "Protein" ;
  smodule:isSelected "true"^^xsd:boolean .

up_mod:M92_module_port-identity
  a smodule:ModulePortDatatype;
  smodule:variableName "?identity" ;
  rdfs:domain [
		a owl:Class ;
		smodule:option ("0.5" "0.9" "1.0")
		]; 
  rdfs:label "Cluster identity" ;
  smodule:isSelected "true"^^xsd:boolean .
