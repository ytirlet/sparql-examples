@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:M87_module a smodule:SPARQLModule;
  rdfs:label "UniProtKB primary accession"@en;
  rdfs:comment "UniProtKB primary accession"@en;
  schema:keywords "identifier";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  """ ;
  smodule:fragmentSPARQL """ 
    ?protein rdf:type up:Protein.
    BIND(substr(str(?protein), strlen(str(uniprotkb:))+1) AS ?primaryAccession)
    """;
  smodule:output up_mod:M87_module_port-protein, up_mod:M87_module_port-primaryAccession.
  
up_mod:M87_module_port-primaryAccession
  a smodule:ModulePortDatatype;
  rdfs:domain xsd:string ;
  smodule:variableName "?primaryAccession" ;
  rdfs:label "Primary accession identifier" ;
  smodule:isSelected "true"^^xsd:boolean .

up_mod:M87_module_port-protein
  a smodule:ModulePortURI;
  rdfs:domain up:Protein;
  smodule:variableName "?protein" ;
  rdfs:label "Protein" ;
  smodule:isSelected "true"^^xsd:boolean .
