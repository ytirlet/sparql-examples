@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:M83_module a smodule:SPARQLModule;
  rdfs:label "Chain sequence mapping"@en;
  rdfs:comment "Chain sequence mappin"@en;
  schema:keywords "mapping";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  """ ;
  smodule:fragmentSPARQL """ 
    ?pdb up:database <http://purl.uniprot.org/database/PDB> ;
       up:chainSequenceMapping ?mappingProtein .
    ?mappingProtein up:chain ?chainsPlusRange .
    """;
  smodule:output up_mod:M83_module_port-pdb, up_mod:M83_module_port-mappingProtein, up_mod:M83_module_port-chainsPlusRange .
  
up_mod:M83_module_port-mappingProtein
  a smodule:ModulePortURI;
  rdfs:domain up:Protein ;
  smodule:variableName "?mappingProtein" ;
  rdfs:label "Mapping Protein" ;
  smodule:isSelected "true"^^xsd:boolean .

up_mod:M83_module_port-pdb
  a smodule:ModulePortURI;
  rdfs:domain up:Resource;
  smodule:variableName "?pdb" ;
  rdfs:label "PDB entry" ;
  smodule:isSelected "true"^^xsd:boolean .
  
up_mod:M83_module_port-chainsPlusRange
  a smodule:ModulePortDatatype;
  rdfs:domain xsd:string ;
  smodule:variableName "?chainsPlusRange" ;
  rdfs:label "Amino Acids chain" ;
  smodule:isSelected "true"^^xsd:boolean .
