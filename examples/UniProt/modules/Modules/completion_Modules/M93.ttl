@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:M93_module a smodule:SPARQLModule;
  rdfs:label "Comment modification for rq 34"@en;
  rdfs:comment "Comment modification for rq 34"@en;
  schema:keywords "comment";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  """ ;
  smodule:fragmentSPARQL """ 
    BIND(IF(contains(?rawComment, ';'), 
            STRBEFORE(?rawComment,';'), 
            ?rawComment) AS ?comment)
    """;
  smodule:output up_mod:M93_module_port-rawComment, up_mod:M93_module_port-comment.
  
up_mod:M93_module_port-comment
  a smodule:ModulePortDatatype;
  rdfs:domain xsd:string ;
  smodule:variableName "?comment" ;
  rdfs:label "comment" ;
  smodule:isSelected "true"^^xsd:boolean .

up_mod:M93_module_port-rawComment
  a smodule:ModulePortDatatype;
  rdfs:domain xsd:string;
  smodule:variableName "?rawComment" ;
  rdfs:label "rawComment" ;
  smodule:isSelected "true"^^xsd:boolean .
