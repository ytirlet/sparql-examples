@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

up_mod:m5_module a smodule:SPARQLModule;
  rdfs:label "chebiRestriction structured name"@en;
  rdfs:comment "chebiRestriction structured name"@en;
  schema:keywords "structured name";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  """ ;
  smodule:fragmentSPARQL """ 
    ?chebiRestriction a owl:Restriction ;
	owl:onProperty chebihash:has_major_microspecies_at_pH_7_3.
    """;
  smodule:output up_mod:m5_module_port-chebiRestriction.
  
up_mod:m5_module_port-chebiRestriction
  a smodule:ModulePortURI;
  rdfs:domain owl:Restriction;
  smodule:variableName "?chebiRestriction" ;
  rdfs:label "ChEBI Restriction" ;
  smodule:isSelected "true"^^xsd:boolean.
