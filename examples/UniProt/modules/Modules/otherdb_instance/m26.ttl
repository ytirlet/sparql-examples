@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:m26_module a smodule:SPARQLModule;
  rdfs:label "englishLabelStr structured name"@en;
  rdfs:comment "englishLabelStr structured name"@en;
  schema:keywords "structured name";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  """ ;
  smodule:fragmentSPARQL """ 
  SERVICE <https://sparql.omabrowser.org/sparql/> {
    SELECT ?orthologous_protein2 ?protein1 ?gene WHERE {
      ?protein_OMA a orth:Protein .
      ?orthologous_protein2 a orth:Protein .
      ?cluster a orth:OrthologsCluster .
      ?cluster orth:hasHomologousMember ?node1 .
      ?cluster orth:hasHomologousMember ?node2 .
      ?node2 orth:hasHomologousMember* ?protein_OMA .
      ?node1 orth:hasHomologousMember* ?orthologous_protein2 
      .?orthologous_protein2 orth:organism/obo:RO_0002162/up:scientificName 'Rattus norvegicus' .
      ?orthologous_protein2 sio:SIO_010079 ?gene .
      ?protein_OMA lscr:xrefUniprot ?protein1 .
      FILTER(?node1 != ?node2)
    }
  }
  SERVICE <https://www.bgee.org/sparql/> {
    ?gene genex:isExpressedIn ?anatEntity .
    ?anatEntity rdfs:label 'brain' .
    ?gene orth:organism ?org . 
    ?org obo:RO_0002162 taxon:10116 .
  }
    """;
  smodule:output up_mod:m26_module_port-protein.
  
up_mod:m26_module_port-protein
  a smodule:ModulePortURI ;
  smodule:variableName "?protein";
  rdfs:domain up:Protein ;
  rdfs:label "protein" ;
  smodule:isSelected "true"^^xsd:boolean.
