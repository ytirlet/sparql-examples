@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:m13_module a smodule:SPARQLModule;
  rdfs:label "englishLabelStr structured name"@en;
  rdfs:comment "englishLabelStr structured name"@en;
  schema:keywords "structured name";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  """ ;
  smodule:fragmentSPARQL """ 
  SERVICE <https://idsm.elixir-czech.cz/sparql/endpoint/chebi> {
    ?ssc sachem:compound ?ligand; 
      sachem:score ?ligandSimilarityScore ;
      sachem:cutoff "8e-1"^^xsd:double ;
      sachem:aromaticityMode sachem:aromaticityDetect ;
      sachem:similarityRadius 1 ;
      sachem:tautomerMode sachem:ignoreTautomers .
  }
    """;
  smodule:output up_mod:m13_module_port-ssc, up_mod:m13_module_port-ligand, up_mod:m13_module_port-ligandSimilarityScore.
  
up_mod:m13_module_port-ssc
  a smodule:ModulePortURI ;
  smodule:variableName "?ssc";
  rdfs:label "ssc" ;
  smodule:isSelected "true"^^xsd:boolean.
  
up_mod:m13_module_port-ligand
  a smodule:ModulePortURI;
  smodule:name "?ligand" ;
  rdfs:label "Ligand" ;
  smodule:isSelected "true"^^xsd:boolean.
  
up_mod:m13_module_port-ligandSimilarityScore
  a smodule:ModulePortTyped;
  smodule:name "?ligandSimilarityScore" ;
  rdfs:label "Ligand similarity score" ;
  smodule:isSelected "true"^^xsd:boolean.
