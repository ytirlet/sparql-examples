@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix rh: <http://rdf.rhea-db.org/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:M38_module a smodule:SPARQLModule ;
  rdfs:label "reaction to compound"@en ;
  rdfs:comment "reaction to compound"@en ;
  schema:keywords "compound" ;
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
    PREFIX rh: <http://rdf.rhea-db.org/>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
    """ ;
  smodule:fragmentSPARQL """
    ?reaction rdfs:subClassOf rh:Reaction.
    ?reaction rh:side ?side.
    ?side rh:contains ?participant.
    ?participant rh:compound ?compound.
    """ ;
  smodule:output up_mod:M38_module_port-reaction, up_mod:M38_module_port-compound.
    
up_mod:M38_module_port-reaction
  a smodule:ModulePortURI ;
  smodule:variableName "?reaction";
  rdfs:domain rh:Reaction ;
  rdfs:label "Reaction" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M38_module_port-compound
  a smodule:ModulePortURI ;
  smodule:variableName "?compound" ;
  rdfs:label "Compound" ;
  smodule:isSelected "true"^^xsd:boolean.
