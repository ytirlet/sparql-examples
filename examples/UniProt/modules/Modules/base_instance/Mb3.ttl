@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix base_mod: <http://base_module.biographs.org/> .

base_mod:Mb3_module a smodule:SPARQLModule;
  rdfs:label "rdfs comment"@en;
  rdfs:comment "Gives comment of element"@en;
  schema:keywords "comment";
  smodule:prefixes """PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  """ ;
  smodule:fragmentSPARQL """ 
    ?subject rdfs:comment ?comment .
    """;
  smodule:output base_mod:Mb3_module_port-subject, base_mod:Mb3_module_port-comment.
  
base_mod:Mb3_module_port-subject
  a smodule:ModulePortURI;
  rdfs:domain rdfs:Resource ;
  smodule:variableName "?subject" ;
  rdfs:label "Subject" ;
  smodule:isSelected "true"^^xsd:boolean .

base_mod:Mb3_module_port-comment
  a smodule:ModulePortTyped;
  rdfs:domain rdfs:Literal;
  smodule:variableName "?comment" ;
  rdfs:label "Comment" ;
  smodule:isSelected "true"^^xsd:boolean .
