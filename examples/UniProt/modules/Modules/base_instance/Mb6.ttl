@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix base_mod: <http://base_module.biographs.org/> .

base_mod:Mb6_module a smodule:SPARQLModule;
  rdfs:label "rdfs sub class of"@en;
  rdfs:comment "Gives class of element"@en;
  schema:keywords "class";
  smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  """ ;
  smodule:fragmentSPARQL """ 
    ?subject rdfs:subClassOf ?class .
    """;
  smodule:output base_mod:Mb6_module_port-subject, base_mod:Mb6_module_port-class.
  
base_mod:Mb6_module_port-subject
  a smodule:ModulePortURI;
  rdfs:domain rdfs:Resource ;
  smodule:variableName "?subject" ;
  rdfs:label "Subject" ;
  smodule:isSelected "true"^^xsd:boolean .

base_mod:Mb6_module_port-class
  a smodule:ModulePortTyped;
  rdfs:domain rdfs:Resource;
  smodule:variableName "?class" ;
  rdfs:label "class" ;
  smodule:isSelected "true"^^xsd:boolean .
