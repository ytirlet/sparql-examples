@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix base_mod: <http://base_module.biographs.org/> .

base_mod:Mb5_module a smodule:SPARQLModule;
  rdfs:label "subject predicate object"@en;
  rdfs:comment "triplet 'subject predicate object' that enables to complete a query"@en;
  schema:keywords "";
  smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  """ ;
  smodule:fragmentSPARQL """ 
    ?subject ?predicate ?object .
    """;
  smodule:output base_mod:Mb5_module_port-subject, base_mod:Mb5_module_port-object, base_mod:Mb5_module_port-predicate .
  
base_mod:Mb5_module_port-subject
  a smodule:ModulePortURI;
  rdfs:domain rdfs:Resource ;
  smodule:variableName "?subject" ;
  rdfs:label "Subject" ;
  smodule:isSelected "true"^^xsd:boolean .

base_mod:Mb5_module_port-object
  a smodule:ModulePortTyped;
  rdfs:domain rdfs:Resource;
  smodule:variableName "?object" ;
  rdfs:label "Object" ;
  smodule:isSelected "true"^^xsd:boolean .
  
base_mod:Mb5_module_port-predicate
  a smodule:ModulePortURI;
  rdfs:domain rdf:Property;
  smodule:variableName "?predicate" ;
  rdfs:label "Predicate" ;
  smodule:isSelected "true"^^xsd:boolean .
