@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

up_mod:M80_module a smodule:SPARQLModule;
  rdfs:label "Entry structured name"@en;
  rdfs:comment "Entry structured name"@en;
  schema:keywords "structured name";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  """ ;
  smodule:fragmentSPARQL """ 
    ?entry rdf:type ?entryType.
    ?entry (up:recommendedName|up:alternativeName) ?structuredName.
    """;
  smodule:output up_mod:M80_module_port-entry, up_mod:M80_module_port-structuredName, up_mod:M80_module_port-entryType.
  
up_mod:M80_module_port-structuredName
  a smodule:ModulePortURI;
  rdfs:domain up:StructuredName ;
  smodule:variableName "?structuredName" ;
  rdfs:label "Structured Name" ;
  smodule:isSelected "true"^^xsd:boolean .
  
up_mod:M80_module_port-entryType
  a smodule:ModulePortURI;
  rdfs:domain [owl:unionOf (up:Protein up:Part)];
  smodule:variableName "?entryType" ;
  rdfs:label "Entry type" ;
  smodule:isSelected "true"^^xsd:boolean .

up_mod:M80_module_port-entry
  a smodule:ModulePortURI;
  rdfs:domain [
		a owl:Class ;
		smodule:option (up:Protein up:Part)
		]; 
  smodule:variableName "?entry" ;
  rdfs:label "Entry" ;
  smodule:isSelected "true"^^xsd:boolean .
