@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:M23_module a smodule:SPARQLModule;
  rdfs:label "Protein GO classification"@en;
  rdfs:comment "Protein GO classification"@en;
  schema:keywords "protein classification", "GO annotation";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
    PREFIX GO:<http://purl.obolibrary.org/obo/GO_>
    """;
  smodule:fragmentSPARQL """
    ?protein up:classifiedWith ?goTerm.
    ?protein rdf:type up:Protein.
    ?goTerm rdfs:subClassOf ?ancestorGOTerm.
    ?goTerm rdfs:label ?label.
    """;
  smodule:output up_mod:M23_module_port-protein, up_mod:M23_module_port-goTerm, up_mod:M23_module_port-ancestorGOTerm, up_mod:M23_module_port-label.

up_mod:M23_module_port-protein
  a smodule:ModulePortURI;
  smodule:variableName "?protein" ;
  rdfs:label "Protein" ;
  rdfs:domain up:Protein ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M23_module_port-goTerm
  a smodule:ModulePortURI;
  smodule:variableName "?goTerm" ;
  rdfs:label "GO Term" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M23_module_port-ancestorGOTerm
  a smodule:ModulePortURI;
  smodule:variableName "?ancestorGOTerm" ;
  rdfs:label "Ancestor GO Term" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M23_module_port-label
  a smodule:ModulePortDatatype;
  rdfs:domain xsd:string ;
  smodule:variableName "?label" ;
  rdfs:label "GO Term Label" ;
  smodule:isSelected "true"^^xsd:boolean.
