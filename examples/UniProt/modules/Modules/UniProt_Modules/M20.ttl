@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:M20_module a smodule:SPARQLModule;
  rdfs:label "Annotation attribution"@en ;
  rdfs:comment "Annotation attribution"@en;
  schema:keywords "annotation", "evidence tag", "PubMed";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  """ ;
  smodule:fragmentSPARQL """
    ?object rdf:object ?annotation.
    ?object up:attribution ?attribution.
    ?attribution up:source ?source.
    ?source rdf:type ?sourceType.
    ?attribution up:evidence ?evidence.
    """;
  smodule:output up_mod:M20_module_port-annotation, up_mod:M20_module_port-object, up_mod:M20_module_port-attribution, up_mod:M20_module_port-sourceType, up_mod:M20_module_port-source, up_mod:M20_module_port-evidence.

up_mod:M20_module_port-annotation
  a smodule:ModulePortURI;
  rdfs:domain up:Annotation ;
  smodule:variableName "?annotation" ;
  rdfs:label "Annotation" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M20_module_port-object
  a smodule:ModulePortURI;
  smodule:variableName "?object" ;
  rdfs:label "Object" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M20_module_port-attribution
  a smodule:ModulePortURI;
  smodule:variableName "?attribution" ;
  rdfs:label "Attribution" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M20_module_port-sourceType
  a smodule:ModulePortURI;
  smodule:variableName "?sourceType" ;
  rdfs:label "Source type" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M20_module_port-source
  a smodule:ModulePortURI;
  smodule:variableName "?source" ;
  rdfs:label "Source" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M20_module_port-evidence
  a smodule:ModulePortURI;
  smodule:variableName "?evidence";
  rdfs:label "Evidence" ;
  smodule:isSelected "true"^^xsd:boolean.
