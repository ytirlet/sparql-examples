@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

up_mod:M29_module a smodule:SPARQLModule;
  rdfs:label "Cluster and similar protein"@en;
  rdfs:comment "Cluster and similar protein"@en;
  schema:keywords "similar protein";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
    """ ;
  smodule:fragmentSPARQL """
    ?cluster up:member ?member.
    ?member up:sequenceFor ?similar.
    ?cluster up:identity ?identity.
    """;
  smodule:output up_mod:M29_module_port-cluster, up_mod:M29_module_port-member, up_mod:M29_module_port-similar, up_mod:M29_module_port-identity .

up_mod:M29_module_port-cluster
  a smodule:ModulePortURI;
  smodule:variableName "?cluster" ;
  rdfs:domain xsd:anyURI ;
  rdfs:label "Cluster" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M29_module_port-similar
  a smodule:ModulePortURI;
  smodule:variableName "?similar" ;
  rdfs:domain xsd:anyURI ;
  rdfs:label "Similar protein" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M29_module_port-member
  a smodule:ModulePortURI;
  smodule:variableName "?member" ;
  rdfs:domain xsd:anyURI ;
  rdfs:label "Member" ;
  smodule:isSelected "true"^^xsd:boolean.
  
up_mod:M29_module_port-identity
  a smodule:ModulePortDatatype;
  smodule:variableName "?identity" ;
  rdfs:domain [
		a owl:Class ;
		smodule:option ("0.5" "0.9" "1.0")
		]; 
  rdfs:label "Cluster identity" ;
  smodule:isSelected "true"^^xsd:boolean .
