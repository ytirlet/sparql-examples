@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

up_mod:M32_module a smodule:SPARQLModule;
  rdfs:label "Entry sequence"@en;
  rdfs:comment "Entry sequence"@en;
  schema:keywords "sequence";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
    """ ;
  smodule:fragmentSPARQL """
    ?entry rdf:type ?entryType.
    ?entry up:sequence ?sequence.
    ?sequence rdf:type ?sequenceType.
    """;
  smodule:output up_mod:M32_module_port-entry, up_mod:M32_module_port-entryType, up_mod:M32_module_port-sequence , up_mod:M32_module_port-sequenceType, up_mod:M32_module_port-value.

up_mod:M32_module_port-entry
  a smodule:ModulePortURI;
  rdfs:domain [
		a owl:Class ;
		smodule:option (up:Annotation up:Resource up:Protein)
		]; 
  smodule:variableName "?entry" ;
  rdfs:label "Entry" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M32_module_port-sequence
  a smodule:ModulePortURI;
  smodule:variableName "?sequence" ;
  rdfs:label "Sequence" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M32_module_port-entryType
  a smodule:ModulePortURI;
  smodule:option (up:Annotation up:Ressource up:Protein) ;
  smodule:variableName "?entryType" ;
  rdfs:label "Entry type" ;
  smodule:isSelected "true"^^xsd:boolean.
  
up_mod:M32_module_port-sequenceType
  a smodule:ModulePortURI;
  smodule:variableName "?sequenceType" ;
  rdfs:label "Sequence type" ;
  smodule:isSelected "true"^^xsd:boolean.
  
up_mod:M32_module_port-value
  a smodule:ModulePortDatatype;
  rdfs:domain xsd:string;
  smodule:variableName "?value" ;
  rdfs:label "Value" ;
  smodule:isSelected "true"^^xsd:boolean.
