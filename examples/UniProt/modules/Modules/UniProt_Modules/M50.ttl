@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:M50_module a smodule:SPARQLModule;
  rdfs:label "protein to ligand"@en;
  rdfs:comment "protein to ligand"@en;
  schema:keywords "protein annotation";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
    PREFIX chebi: <http://purl.obolibrary.org/obo/CHEBI_>
    """ ;
  smodule:fragmentSPARQL """
    ?annotation up:ligand ?ligand.
    ?ligand rdfs:subClassOf ?chebi.
    """;
  smodule:output up_mod:M50_module_port-annotation, up_mod:M50_module_port-ligand, up_mod:M50_module_port-chebi .

up_mod:M50_module_port-annotation
  a smodule:ModulePortURI;
  rdfs:domain up:Annotation;
  smodule:name "?annotation" ;
  rdfs:label "Annotation" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M50_module_port-chebi
  a smodule:ModulePortURI;
  smodule:name "?chebi" ;
  rdfs:label "ChEBI" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M50_module_port-ligand
  a smodule:ModulePortURI;
  smodule:name "?ligand" ;
  rdfs:label "Ligand" ;
  smodule:isSelected "true"^^xsd:boolean.
