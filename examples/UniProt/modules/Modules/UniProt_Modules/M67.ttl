@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix uniprotkb: <http://purl.uniprot.org/uniprot/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:M67_module a smodule:SPARQLModule ;
  rdfs:label "Entry to taxon"@en ;
  rdfs:comment "Entry to taxon"@en ;
  schema:keywords "taxon" ;
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
    PREFIX taxon: <http://purl.uniprot.org/taxonomy/>
    """ ;
  smodule:fragmentSPARQL """
    ?entry up:organism ?organism.
    ?organism rdfs:subClassOf? ?taxon. # Hierarchy of taxon is materialized
    """ ;
  smodule:output up_mod:M67_module_port-entry, up_mod:M67_module_port-organism, up_mod:M67_module_port-taxon .
    
up_mod:M67_module_port-entry
  a smodule:ModulePort ; 
  smodule:variableName "?entry" ; 
  rdfs:domain xsd:anyURI ;
  smodule:example (uniprotkb:P01308 uniprotkb:A0A002 uniprotkb:A0A008ARC3) ;
  rdfs:label "Entry" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M67_module_port-organism 
  a smodule:ModulePort ;
  rdfs:domain up:Taxon;
  smodule:variableName "?organism" ;
  rdfs:label "Organism" ;
  smodule:isSelected "true"^^xsd:boolean.
	
up_mod:M67_module_port-taxon
  a smodule:ModulePort ; 
  rdfs:domain up:Taxon;
  smodule:variableName "?taxon" ;
  rdfs:label "Organism' ancestors Class (incl. self)" ;
  smodule:isSelected "true"^^xsd:boolean.
