@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:M72_module a smodule:SPARQLModule ;
  rdfs:label "Entry Names"@en;
  rdfs:comment "Entry, recommended name and full name"@en;
  schema:keywords "name";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
    """ ;
  smodule:fragmentSPARQL """
    ?entry up:recommendedName ?recName.
    ?entry up:alternativeName ?altName.
    ?recName up:fullName ?fullName.
    ?recName up:shortName ?shortName.
    """;
  smodule:output up_mod:M72_moduleport-entry, up_mod:M72_module_port-recName, up_mod:M72_module_port-altName, up_mod:M72_module_port-fullName, up_mod:M72_module_port-shortName .

up_mod:M72_module_port-fullName
  a smodule:ModulePortURI;
  rdfs:domain up:Structured_Name ;
  smodule:variableName "?fullName" ;
  rdfs:label "Full Name" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M72_module_port-shortName
  a smodule:ModulePortURI;
  rdfs:domain up:Structured_Name ;
  smodule:variableName "?shortName" ;
  rdfs:label "Short Name" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M72_module_port-recName
  a smodule:ModulePortURI;
  rdfs:domain up:Structured_Name ;
  smodule:variableName "r?ecName" ;
  rdfs:label "Recommended Name" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M72_module_port-entry
  a smodule:ModulePortURI;
  rdfs:domain [
		a owl:Class ;
		smodule:option (up:Protein up:Part)
		]; 
  smodule:variableName "?entry" ;
  rdfs:label "Entry" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M72_module_port-altName
  a smodule:ModulePortURI;
  rdfs:domain up:Structured_Name ;
  smodule:variableName "?altName" ;
  rdfs:label "Alternative Name" ;
  smodule:isSelected "true"^^xsd:boolean.
