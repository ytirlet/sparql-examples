@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:M17_module a smodule:SPARQLModule;
  rdfs:label "Protein information"@en;
  rdfs:comment "Protein information"@en;
  schema:keywords "date", "entry history";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  """;
  smodule:fragmentSPARQL """
    ?protein rdf:type up:Protein ;
      up:created ?creationDate ;
      up:modified ?modificationDate ;
      up:reviewed ?reviewed ;
      up:version ?version .
    """;
  smodule:output up_mod:M17_module_port-protein, up_mod:M17_module_port-creationDate, up_mod:M17_module_port-modificationDate, up_mod:M17_module_port-reviewed, up_mod:M17_module_port-version.

up_mod:M17_module_port-creationDate
  a smodule:ModulePortURI;
  rdfs:domain xsd:date ;
  smodule:variableName "?creationDate" ;
  rdfs:label "date of creation" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M17_module_port-protein
  a smodule:ModulePortURI;
  rdfs:domain up:Protein ;
  smodule:variableName "?protein" ;
  rdfs:label "Protein" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M17_module_port-modificationDate
  a smodule:ModulePortDatatype;
  rdfs:domain xsd:date ;
  smodule:variableName "?modificationDate" ;
  rdfs:label "date of modification" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M17_module_port-reviewed
  a smodule:ModulePortDatatype;
  rdfs:domain xsd:boolean ;
  smodule:variableName "?reviewed" ;
  rdfs:label "is reviewed" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M17_module_port-version
  a smodule:ModulePortDatatype;
  rdfs:domain xsd:int ;
  smodule:variableName "?version" ;
  rdfs:label "Version" ;
  smodule:isSelected "true"^^xsd:boolean.
