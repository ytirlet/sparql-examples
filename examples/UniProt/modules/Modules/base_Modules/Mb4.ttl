@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix base_mod: <http://base_module.biographs.org/> .

base_mod:Mb4_module a smodule:SPARQLModule;
  rdfs:label "rdf type"@en;
  rdfs:comment "Gives type of element"@en;
  schema:keywords "type";
  smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  """ ;
  smodule:fragmentSPARQL """ 
    ?subject rdf:type ?type .
    """;
  smodule:output base_mod:Mb4_module_port-subject, base_mod:Mb4_module_port-type.
  
base_mod:Mb4_module_port-subject
  a smodule:ModulePortURI;
  rdfs:domain rdfs:Resource ;
  smodule:variableName "?subject" ;
  rdfs:label "Subject" ;
  smodule:isSelected "true"^^xsd:boolean .

base_mod:Mb4_module_port-type
  a smodule:ModulePortTyped;
  rdfs:domain rdfs:Class;
  smodule:variableName "?type" ;
  rdfs:label "Type" ;
  smodule:isSelected "true"^^xsd:boolean .
