@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M89_moduleClone1> a smodule:SPARQLModule ;
    rdfs:label "Protein domain to enzyme " ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M89_module> ;
    smodule:fragmentSPARQL """ 
    ?proteinClone1 up:domain ?domainClone1.
    ?domainClone1 up:enzyme ?enzymeClone1 .
    ?enzymeClone1 rdfs:subClassOf? ?ecClassClone1.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M89_module_port-domainClone1>,
        <http://uniprot_module.biographs.org/M89_module_port-ecClassClone1>,
        <http://uniprot_module.biographs.org/M89_module_port-enzymeClone1>,
        <http://uniprot_module.biographs.org/M89_module_port-proteinClone1> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M89_module_port-domainClone1> a smodule:ModulePortURI ;
    rdfs:label "Protein domain" ;
    rdfs:domain up:Part ;
    smodule:isSelected false ;
    smodule:variableName "?domainClone1" .

<http://uniprot_module.biographs.org/M89_module_port-ecClassClone1> a smodule:ModulePortURI ;
    rdfs:label "Enzyme Class" ;
    rdfs:domain up:Enzyme ;
    smodule:isSelected true ;
    smodule:variableName "?ecClassClone1" .

<http://uniprot_module.biographs.org/M89_module_port-enzymeClone1> a smodule:ModulePortURI ;
    rdfs:label "Enzyme" ;
    rdfs:domain up:Enzyme ;
    smodule:isSelected false ;
    smodule:variableName "?enzymeClone1" .

<http://uniprot_module.biographs.org/M89_module_port-proteinClone1> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:protein ;
    smodule:isSelected true ;
    smodule:variableName "?proteinClone1" .

