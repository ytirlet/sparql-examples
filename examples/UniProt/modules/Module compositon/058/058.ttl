@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .
@prefix uniprotkb: <http://purl.uniprot.org/uniprot/> .
@prefix base_mod: <http://base_module.biographs.org/> .


smodule:module_composition_058 dcterms:title "Map a selection of UniProtKB accession numbers (ACs) to HGNC identifiers and symbols".
smodule:module_composition_058 rdfs:comment "Map a selection of UniProtKB accession numbers (ACs) to HGNC identifiers and symbols".
smodule:module_composition_058 dcterms:subject "mapping", "HGNC".

smodule:module_composition_058 rdf:type smodule:SPARQL_Module_Composition.
smodule:module_composition_058 smodule:hasConnection smodule:058_c1, smodule:058_c2.
smodule:module_composition_058 smodule:hasComponent smodule:OperatorValuesClone77, base_mod:Mb3_moduleClone2, up_mod:M31_moduleClone8.
smodule:module_composition_058 smodule:includeFile "VALUESClone77.ttl", "Mb3Clone2.ttl", "M31Clone8.ttl".

smodule:058_c1 rdf:type smodule:Connection.
smodule:058_c1 smodule:connects up_mod:M31_module_port-entryClone8, smodule:OperatorValuesPortResultClone77.

smodule:OperatorValuesPortResultClone77 smodule:valuesEnumeration "uniprotkb:P05067 uniprotkb:P00750" .

smodule:058_c2 rdf:type smodule:Connection.
smodule:058_c2 smodule:connects up_mod:M31_module_port-dbentryClone8, base_mod:Mb3_module_port-subjectClone2.
