@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M14_moduleClone16> a smodule:SPARQLModule ;
    rdfs:label "Protein annotation" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M14_module> ;
    smodule:fragmentSPARQL """ 
    ?proteinClone16 rdf:type up:Protein.
    ?proteinClone16 up:annotation ?annotationClone16.
    ?annotationClone16 rdf:type ?annotationTypeClone16.
    ?annotationClone16 rdfs:comment ?commentClone16.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M14_module_port-annotationClone16>,
        <http://uniprot_module.biographs.org/M14_module_port-annotationTypeClone16>,
        <http://uniprot_module.biographs.org/M14_module_port-commentClone16>,
        <http://uniprot_module.biographs.org/M14_module_port-proteinClone16> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M14_module_port-annotationClone16> a smodule:ModulePortURI ;
    rdfs:label "Annotation" ;
    rdfs:domain up:Annotation ;
    smodule:isSelected false ;
    smodule:variableName "?annotationClone16" .

<http://uniprot_module.biographs.org/M14_module_port-annotationTypeClone16> a smodule:ModulePortURI ;
    rdfs:label "Type of annotation" ;
    rdfs:domain up:Annotation ;
    smodule:isSelected false ;
    smodule:variableName "?annotationTypeClone16" .

<http://uniprot_module.biographs.org/M14_module_port-commentClone16> a smodule:ModulePortDatatype ;
    rdfs:label "Annotation comment" ;
    rdfs:domain xsd:string ;
    smodule:isSelected false ;
    smodule:variableName "?commentClone16" .

<http://uniprot_module.biographs.org/M14_module_port-proteinClone16> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:Protein ;
    smodule:isSelected false ;
    smodule:variableName "?proteinClone16" .

