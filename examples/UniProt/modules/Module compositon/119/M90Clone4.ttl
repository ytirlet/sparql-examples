@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M90_moduleClone4> a smodule:SPARQLModule ;
    rdfs:label "Protein component to enzyme " ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M90_module> ;
    smodule:fragmentSPARQL """ 
    ?proteinClone4 up:component ?componentClone4.
    ?componentClone4 up:enzyme ?enzymeClone4 .
    ?enzymeClone4 rdfs:subClassOf? ?ecClassClone4.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M90_module_port-componentClone4>,
        <http://uniprot_module.biographs.org/M90_module_port-ecClassClone4>,
        <http://uniprot_module.biographs.org/M90_module_port-enzymeClone4>,
        <http://uniprot_module.biographs.org/M90_module_port-proteinClone4> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M90_module_port-componentClone4> a smodule:ModulePortURI ;
    rdfs:label "Protein component" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?componentClone4" .

<http://uniprot_module.biographs.org/M90_module_port-ecClassClone4> a smodule:ModulePortURI ;
    rdfs:label "Enzyme Class" ;
    rdfs:domain up:Enzyme ;
    smodule:isSelected false ;
    smodule:variableName "?ecClassClone4" .

<http://uniprot_module.biographs.org/M90_module_port-enzymeClone4> a smodule:ModulePortURI ;
    rdfs:label "Enzyme" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected true ;
    smodule:variableName "?enzymeClone4" .

<http://uniprot_module.biographs.org/M90_module_port-proteinClone4> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?proteinClone4" .

