@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M31_moduleClone13> a smodule:SPARQLModule ;
    rdfs:label "Entry and database" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M31_module> ;
    smodule:fragmentSPARQL """
    ?entryClone13 rdf:type ?entryTypeClone13.
    ?entryClone13 rdfs:seeAlso ?dbentryClone13.
    ?dbentryClone13 up:database ?databaseClone13.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M31_module_port-databaseClone13>,
        <http://uniprot_module.biographs.org/M31_module_port-dbentryClone13>,
        <http://uniprot_module.biographs.org/M31_module_port-entryClone13>,
        <http://uniprot_module.biographs.org/M31_module_port-entryTypeClone13> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M31_module_port-databaseClone13> a smodule:ModulePortURI ;
    rdfs:label "Database" ;
    rdfs:domain up:Database ;
    smodule:isSelected false ;
    smodule:variableName "?databaseClone13" .

<http://uniprot_module.biographs.org/M31_module_port-dbentryClone13> a smodule:ModulePortURI ;
    rdfs:label "Database entry" ;
    rdfs:domain up:Ressource ;
    smodule:isSelected false ;
    smodule:variableName "?dbentryClone13" .

<http://uniprot_module.biographs.org/M31_module_port-entryClone13> a smodule:ModulePortURI ;
    rdfs:label "Entry" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected true ;
    smodule:variableName "?entryClone13" .

<http://uniprot_module.biographs.org/M31_module_port-entryTypeClone13> a smodule:ModulePortURI ;
    rdfs:label "Entry type" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?entryTypeClone13" .

