@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:M50_moduleClone2 a smodule:SPARQLModule;
  rdfs:label "protein to ligand"@en;
  rdfs:comment "protein to ligand"@en;
  smodule:clonedFrom <http://uniprot_module.biographs.org/M50_module> ;
  schema:keywords "protein annotation";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
    PREFIX chebi: <http://purl.obolibrary.org/obo/CHEBI_>
    """ ;
  smodule:fragmentSPARQL """
    ?annotationClone2 up:ligand ?ligandClone2.
    ?ligandClone2 rdfs:subClassOf ?chebiClone2.
    """;
  smodule:output up_mod:M50_module_port-annotationClone2, up_mod:M50_module_port-ligandClone2, up_mod:M50_module_port-chebiClone2 .

up_mod:M50_module_port-annotationClone2
  a smodule:ModulePortURI;
  rdfs:domain up:Annotation;
  smodule:variableName "?annotationClone2" ;
  rdfs:label "Annotation" ;
  smodule:isSelected "false"^^xsd:boolean.

up_mod:M50_module_port-chebiClone2
  a smodule:ModulePortURI;
  smodule:variableName "?chebiClone2" ;
  rdfs:label "ChEBI" ;
  smodule:isSelected "false"^^xsd:boolean.

up_mod:M50_module_port-ligandClone2
  a smodule:ModulePortURI;
  smodule:variableName "?ligandClone2" ;
  rdfs:label "Ligand" ;
  smodule:isSelected "true"^^xsd:boolean.
