@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M20_moduleClone4> a smodule:SPARQLModule ;
    rdfs:label "Annotation attribution" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M20_module> ;
    smodule:fragmentSPARQL """
    ?objectClone4 rdf:object ?annotationClone4.
    ?objectClone4 up:attribution ?attributionClone4.
    ?attributionClone4 up:source ?sourceClone4.
    ?sourceClone4 rdf:type ?sourceTypeClone4.
    ?attributionClone4 up:evidence ?evidenceClone4.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M20_module_port-annotationClone4>,
        <http://uniprot_module.biographs.org/M20_module_port-attributionClone4>,
        <http://uniprot_module.biographs.org/M20_module_port-evidenceClone4>,
        <http://uniprot_module.biographs.org/M20_module_port-objectClone4>,
        <http://uniprot_module.biographs.org/M20_module_port-sourceClone4>,
        <http://uniprot_module.biographs.org/M20_module_port-sourceTypeClone4> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M20_module_port-annotationClone4> a smodule:ModulePortURI ;
    rdfs:label "Annotation" ;
    rdfs:domain up:Annotation ;
    smodule:isSelected false ;
    smodule:variableName "?annotationClone4" .

<http://uniprot_module.biographs.org/M20_module_port-attributionClone4> a smodule:ModulePortURI ;
    rdfs:label "Attribution" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?attributionClone4" .

<http://uniprot_module.biographs.org/M20_module_port-evidenceClone4> a smodule:ModulePortURI ;
    rdfs:label "Evidence" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?evidenceClone4" .

<http://uniprot_module.biographs.org/M20_module_port-objectClone4> a smodule:ModulePortURI ;
    rdfs:label "Object" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?objectClone4" .

<http://uniprot_module.biographs.org/M20_module_port-sourceClone4> a smodule:ModulePortURI ;
    rdfs:label "Source" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?sourceClone4" .

<http://uniprot_module.biographs.org/M20_module_port-sourceTypeClone4> a smodule:ModulePortURI ;
    rdfs:label "Source type" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?sourceTypeClone4" .

