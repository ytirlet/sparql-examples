@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

<http://uniprot_module.biographs.org/M76_moduleClone3> a smodule:SPARQLModule ;
    rdfs:label "faldo: start/end position and reference" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M76_module> ;
    smodule:fragmentSPARQL """
    ?entryClone3 faldo:begin ?faldoBeginClone3.
    ?faldoBeginClone3 faldo:position ?beginPositionClone3.
    ?faldoBeginClone3 faldo:reference ?referenceClone3.
    ?entryClone3 faldo:end ?faldoEndClone3.
    ?faldoEndClone3 faldo:position ?endPositionClone3.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M76_module_port-beginPositionClone3>,
        <http://uniprot_module.biographs.org/M76_module_port-endPositionClone3>,
        <http://uniprot_module.biographs.org/M76_module_port-entryClone3>,
        <http://uniprot_module.biographs.org/M76_module_port-faldoBeginClone3>,
        <http://uniprot_module.biographs.org/M76_module_port-faldoEndClone3>,
        <http://uniprot_module.biographs.org/M76_module_port-referenceClone3> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX faldo: <http://biohackathon.org/resource/faldo#>

""" .

<http://uniprot_module.biographs.org/M76_module_port-beginPositionClone3> a smodule:ModulePortURI ;
    rdfs:label "Begin Position" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected true ;
    smodule:variableName "?beginPositionClone3" .

<http://uniprot_module.biographs.org/M76_module_port-endPositionClone3> a smodule:ModulePortURI ;
    rdfs:label "End Position" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected true ;
    smodule:variableName "?endPositionClone3" .

<http://uniprot_module.biographs.org/M76_module_port-entryClone3> a smodule:ModulePortURI ;
    rdfs:label "Entry" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?entryClone3" .

<http://uniprot_module.biographs.org/M76_module_port-faldoBeginClone3> a smodule:ModulePortURI ;
    rdfs:label "FALDO begin" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?faldoBeginClone3" .

<http://uniprot_module.biographs.org/M76_module_port-faldoEndClone3> a smodule:ModulePortURI ;
    rdfs:label "FALDO end" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?faldoEndClone3" .

<http://uniprot_module.biographs.org/M76_module_port-referenceClone3> a smodule:ModulePortURI ;
    rdfs:label "Reference" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?referenceClone3" .

