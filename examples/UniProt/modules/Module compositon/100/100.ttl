@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

smodule:module_composition_100 dcterms:title "List the proteins encoded by a gene that is located in an organelle other than the nucleus, or on a plasmid rather than a chromosome. In these cases the gene location is stored with encodedIn properties. Note that if a plasmid has several names, they are listed as multiple rdfs:label properties".
smodule:module_composition_100 rdfs:comment "List the proteins encoded by a gene that is located in an organelle other than the nucleus, or on a plasmid rather than a chromosome. In these cases the gene location is stored with encodedIn properties. Note that if a plasmid has several names, they are listed as multiple rdfs:label properties".
smodule:module_composition_100 dcterms:subject "chromosome", "list".

smodule:module_composition_100 rdf:type smodule:SPARQL_Module_Composition.
smodule:module_composition_100 smodule:hasComponent up_mod:M61_moduleClone1.
smodule:module_composition_100 smodule:includeFile "M61Clone1.ttl".
