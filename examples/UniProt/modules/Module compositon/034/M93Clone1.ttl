@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M93_moduleClone1> a smodule:SPARQLModule ;
    rdfs:label "Comment modification for rq 34" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M93_module> ;
    smodule:fragmentSPARQL """ 
    BIND(IF(contains(?rawCommentClone1, ';'), 
            STRBEFORE(?rawCommentClone1,';'), 
            ?rawComment) AS ?comment)
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M93_module_port-commentClone1>,
        <http://uniprot_module.biographs.org/M93_module_port-rawCommentClone1> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

""" .

<http://uniprot_module.biographs.org/M93_module_port-commentClone1> a smodule:ModulePortDatatype ;
    rdfs:label "comment" ;
    rdfs:domain xsd:string ;
    smodule:isSelected true ;
    smodule:variableName "?commentClone1" .

<http://uniprot_module.biographs.org/M93_module_port-rawCommentClone1> a smodule:ModulePortDatatype ;
    rdfs:label "rawComment" ;
    rdfs:domain xsd:string ;
    smodule:isSelected false ;
    smodule:variableName "?rawCommentClone1" .

