@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M14_moduleClone9> a smodule:SPARQLModule ;
    rdfs:label "Protein annotation" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M14_module> ;
    smodule:fragmentSPARQL """ 
    ?proteinClone9 rdf:type up:Protein.
    ?proteinClone9 up:annotation ?annotationClone9.
    ?annotationClone9 rdf:type ?annotationTypeClone9.
    ?annotationClone9 rdfs:comment ?commentClone9.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M14_module_port-annotationClone9>,
        <http://uniprot_module.biographs.org/M14_module_port-annotationTypeClone9>,
        <http://uniprot_module.biographs.org/M14_module_port-commentClone9>,
        <http://uniprot_module.biographs.org/M14_module_port-proteinClone9> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M14_module_port-annotationClone9> a smodule:ModulePortURI ;
    rdfs:label "Annotation" ;
    rdfs:domain up:Annotation ;
    smodule:isSelected false ;
    smodule:variableName "?annotationClone9" .

<http://uniprot_module.biographs.org/M14_module_port-annotationTypeClone9> a smodule:ModulePortURI ;
    rdfs:label "Type of annotation" ;
    rdfs:domain up:Annotation ;
    smodule:isSelected false ;
    smodule:variableName "?annotationTypeClone9" .

<http://uniprot_module.biographs.org/M14_module_port-commentClone9> a smodule:ModulePortDatatype ;
    rdfs:label "Annotation comment" ;
    rdfs:domain xsd:string ;
    smodule:isSelected false ;
    smodule:variableName "?commentClone9" .

<http://uniprot_module.biographs.org/M14_module_port-proteinClone9> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:Protein ;
    smodule:isSelected false ;
    smodule:variableName "?proteinClone9" .

