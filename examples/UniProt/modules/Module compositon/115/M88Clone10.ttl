@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M88_moduleClone10> a smodule:SPARQLModule ;
    rdfs:label "Protein to enzyme" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M88_module> ;
    smodule:fragmentSPARQL """ 
    ?proteinClone10 up:enzyme ?enzymeClone10 .
    ?enzymeClone10 rdfs:subClassOf? ?ecClassClone10.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M88_module_port-ecClassClone10>,
        <http://uniprot_module.biographs.org/M88_module_port-enzymeClone10>,
        <http://uniprot_module.biographs.org/M88_module_port-proteinClone10> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M88_module_port-ecClassClone10> a smodule:ModulePortURI ;
    rdfs:label "Enzyme Class" ;
    rdfs:domain up:Enzyme ;
    smodule:isSelected false ;
    smodule:variableName "?ecClassClone10" .

<http://uniprot_module.biographs.org/M88_module_port-enzymeClone10> a smodule:ModulePortURI ;
    rdfs:label "Enzyme" ;
    rdfs:domain up:Enzyme ;
    smodule:isSelected true ;
    smodule:variableName "?enzymeClone10" .

<http://uniprot_module.biographs.org/M88_module_port-proteinClone10> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:protein ;
    smodule:isSelected false ;
    smodule:variableName "?proteinClone10" .

