@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M89_moduleClone3> a smodule:SPARQLModule ;
    rdfs:label "Protein domain to enzyme " ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M89_module> ;
    smodule:fragmentSPARQL """ 
    ?proteinClone3 up:domain ?domainClone3.
    ?domainClone3 up:enzyme ?enzymeClone3 .
    ?enzymeClone3 rdfs:subClassOf? ?ecClassClone3.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M89_module_port-domainClone3>,
        <http://uniprot_module.biographs.org/M89_module_port-ecClassClone3>,
        <http://uniprot_module.biographs.org/M89_module_port-enzymeClone3>,
        <http://uniprot_module.biographs.org/M89_module_port-proteinClone3> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M89_module_port-domainClone3> a smodule:ModulePortURI ;
    rdfs:label "Protein domain" ;
    rdfs:domain up:Part ;
    smodule:isSelected false ;
    smodule:variableName "?domainClone3" .

<http://uniprot_module.biographs.org/M89_module_port-ecClassClone3> a smodule:ModulePortURI ;
    rdfs:label "Enzyme Class" ;
    rdfs:domain up:Enzyme ;
    smodule:isSelected false ;
    smodule:variableName "?ecClassClone3" .

<http://uniprot_module.biographs.org/M89_module_port-enzymeClone3> a smodule:ModulePortURI ;
    rdfs:label "Enzyme" ;
    rdfs:domain up:Enzyme ;
    smodule:isSelected true ;
    smodule:variableName "?enzymeClone3" .

<http://uniprot_module.biographs.org/M89_module_port-proteinClone3> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:protein ;
    smodule:isSelected false ;
    smodule:variableName "?proteinClone3" .

