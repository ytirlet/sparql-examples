@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M14_moduleClone7> a smodule:SPARQLModule ;
    rdfs:label "Protein annotation" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M14_module> ;
    smodule:fragmentSPARQL """ 
    ?proteinClone7 rdf:type up:Protein.
    ?proteinClone7 up:annotation ?annotationClone7.
    ?annotationClone7 rdf:type ?annotationTypeClone7.
    ?annotationClone7 rdfs:comment ?commentClone7.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M14_module_port-annotationClone7>,
        <http://uniprot_module.biographs.org/M14_module_port-annotationTypeClone7>,
        <http://uniprot_module.biographs.org/M14_module_port-commentClone7>,
        <http://uniprot_module.biographs.org/M14_module_port-proteinClone7> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M14_module_port-annotationClone7> a smodule:ModulePortURI ;
    rdfs:label "Annotation" ;
    rdfs:domain up:Annotation ;
    smodule:isSelected true ;
    smodule:variableName "?annotationClone7" .

<http://uniprot_module.biographs.org/M14_module_port-annotationTypeClone7> a smodule:ModulePortURI ;
    rdfs:label "Type of annotation" ;
    rdfs:domain up:Annotation ;
    smodule:isSelected false ;
    smodule:variableName "?annotationTypeClone7" .

<http://uniprot_module.biographs.org/M14_module_port-commentClone7> a smodule:ModulePortDatatype ;
    rdfs:label "Annotation comment" ;
    rdfs:domain xsd:string ;
    smodule:isSelected true ;
    smodule:variableName "?commentClone7" .

<http://uniprot_module.biographs.org/M14_module_port-proteinClone7> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:Protein ;
    smodule:isSelected false ;
    smodule:variableName "?proteinClone7" .

