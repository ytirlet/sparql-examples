@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M73_moduleClone6> a smodule:SPARQLModule ;
    rdfs:label "protein to gene" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M73_module> ;
    smodule:fragmentSPARQL """
    ?proteinClone6 rdf:type up:Protein.
    ?proteinClone6 up:encodedBy ?geneClone6.
    ?geneClone6 skos:prefLabel ?nameClone6.
    OPTIONAL {?geneClone6 up:locusName ?locusNameClone6.}
    OPTIONAL {?geneClone6 skos:altLabel ?altLabelClone6.}
    OPTIONAL {?geneClone6 up:orfName ?orfNameClone6.}
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M73_module_port-altLabelClone6>,
        <http://uniprot_module.biographs.org/M73_module_port-geneClone6>,
        <http://uniprot_module.biographs.org/M73_module_port-locusNameClone6>,
        <http://uniprot_module.biographs.org/M73_module_port-orfNameClone6>,
        <http://uniprot_module.biographs.org/M73_module_port-proteinClone6> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M73_module_port-altLabelClone6> a smodule:ModulePortDatatype ;
    rdfs:label "Alternative label" ;
    rdfs:domain xsd:string ;
    smodule:isSelected true ;
    smodule:variableName "?altLabelClone6" .

<http://uniprot_module.biographs.org/M73_module_port-geneClone6> a smodule:ModulePortURI ;
    rdfs:label "Gene" ;
    rdfs:domain up:Gene ;
    smodule:isSelected true ;
    smodule:variableName "?geneClone6" .

<http://uniprot_module.biographs.org/M73_module_port-locusNameClone6> a smodule:ModulePortDatatype ;
    rdfs:label "Locus name" ;
    rdfs:domain xsd:string ;
    smodule:isSelected true ;
    smodule:variableName "?locusNameClone6" .

<http://uniprot_module.biographs.org/M73_module_port-orfNameClone6> a smodule:ModulePortDatatype ;
    rdfs:label "ORF name" ;
    rdfs:domain xsd:string ;
    smodule:isSelected true ;
    smodule:variableName "?orfNameClone6" .

<http://uniprot_module.biographs.org/M73_module_port-proteinClone6> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:Protein ;
    smodule:isSelected true ;
    smodule:variableName "?proteinClone6" .

