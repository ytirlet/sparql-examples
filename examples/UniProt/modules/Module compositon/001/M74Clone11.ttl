@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M74_moduleClone11> a smodule:SPARQLModule ;
    rdfs:label "Taxon, Scientific name and ancestor Class" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M74_module> ;
    smodule:fragmentSPARQL """
    ?taxonClone11 rdf:type up:Taxon.
    ?taxonClone11 up:scientificName ?nameClone11.
    ?taxonClone11 rdfs:subClassOf ?ancestorTaxonClone11.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M74_module_port-ancestorTaxonClone11>,
        <http://uniprot_module.biographs.org/M74_module_port-nameClone11>,
        <http://uniprot_module.biographs.org/M74_module_port-taxonClone11> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M74_module_port-ancestorTaxonClone11> a smodule:ModulePortURI ;
    rdfs:label "Ancestor taxon" ;
    rdfs:domain up:Taxon ;
    smodule:isSelected false ;
    smodule:variableName "?ancestorTaxonClone11" .

<http://uniprot_module.biographs.org/M74_module_port-nameClone11> a smodule:ModulePortDatatype ;
    rdfs:label "Taxon name" ;
    rdfs:domain xsd:string ;
    smodule:isSelected false ;
    smodule:variableName "?nameClone11" .

<http://uniprot_module.biographs.org/M74_module_port-taxonClone11> a smodule:ModulePortURI ;
    rdfs:label "Taxon" ;
    rdfs:domain up:Taxon ;
    smodule:isSelected true ;
    smodule:variableName "?taxonClone11" .

