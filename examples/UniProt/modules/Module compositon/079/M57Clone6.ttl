@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

up_mod:M57_moduleClone6 a smodule:SPARQLModule ;
  rdfs:label "entry mnemonic"@en ;
  rdfs:comment "entry mnemonic"@en ;
  smodule:clonedFrom <http://uniprot_module.biographs.org/M57_module> ;
  schema:keywords "mnemonic" ;
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
    """ ;
  smodule:fragmentSPARQL """
    ?entryClone6 rdf:type ?typeClone6.
    ?entryClone6 up:mnemonic ?mnemonicClone6.
    OPTIONAL {?entryClone6 up:oldMnemonic ?oldmnemonicClone6.}
    """ ;
  smodule:output up_mod:M57_module_port-entryClone6, up_mod:M57_module_port-typeClone6, up_mod:M57_module_port-mnemonicClone6, up_mod:M57_module_port-oldmnemonicClone6 .
    
up_mod:M57_module_port-entryClone6
  a smodule:ModulePortURI ; 
  smodule:variableName "?entryClone6" ; 
  rdfs:domain [
    a owl:Class ;
    smodule:option (up:Cluster up:Protein up:Sequence)
    ]; 
  rdfs:label "Entry" ;
  smodule:isSelected "true"^^xsd:boolean.
	
up_mod:M57_module_port-typeClone6
  a smodule:ModulePortURI ; 
  smodule:variableName "?typeClone6" ;
  smodule:option (up:Cluster up:Protein up:Sequence) ;
  rdfs:label "Entry type" ;
  smodule:isSelected "true"^^xsd:boolean.
	
up_mod:M57_module_port-mnemonicClone6
  a smodule:ModulePortDatatype ; 
  smodule:variableName "?mnemonicClone6" ;
  rdfs:domain xsd:string ;
  smodule:example "A4_HUMAN", "1433E_MOUSE", "1FEH2_WHEAT" ;
  rdfs:label "Mnemonic" ;
  smodule:isSelected "true"^^xsd:boolean.
	
up_mod:M57_module_port-oldmnemonicClone6 
  a smodule:ModulePortDatatype ;
  smodule:variableName "?oldmnemonicClone6" ;
  rdfs:domain xsd:string ;
  rdfs:label "Old mnemonic" ;
  smodule:isSelected "true"^^xsd:boolean.
