@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix base_mod: <http://base_module.biographs.org/> .

<http://base_module.biographs.org/Mb2_moduleClone2> a smodule:SPARQLModule ;
    rdfs:label "rdfs label" ;
    smodule:clonedFrom <http://base_module.biographs.org/Mb2_module> ;
    smodule:fragmentSPARQL """ 
    ?subjectClone2 rdfs:label ?labelClone2 .
    """ ;
    smodule:output <http://base_module.biographs.org/Mb2_module_port-subjectClone2>,  base_mod:Mb2_module_port-labelClone2 ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

""" .

<http://base_module.biographs.org/Mb2_module_port-subjectClone2> a smodule:ModulePortURI ;
    rdfs:label "Subject" ;
    rdfs:domain rdfs:Resource ;
    smodule:isSelected false ;
    smodule:variableName "?subjectClone2" .
    
base_mod:Mb2_module_port-labelClone2
  a smodule:ModulePortTyped;
  rdfs:domain rdfs:Literal;
  smodule:variableName "?labelClone2" ;
  rdfs:label "Label" ;
  smodule:isSelected "true"^^xsd:boolean .

