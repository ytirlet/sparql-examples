@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix base_mod: <http://base_module.biographs.org/> .

<http://base_module.biographs.org/Mb1_moduleClone5> a smodule:SPARQLModule ;
    rdfs:label "rdf value" ;
    smodule:clonedFrom <http://base_module.biographs.org/Mb1_module> ;
    smodule:fragmentSPARQL """ 
    ?subjectClone5 rdf:value ?valueClone5 .
    """ ;
    smodule:output <http://base_module.biographs.org/Mb1_module_port-subjectClone5>, <http://base_module.biographs.org/Mb1_module_port-valueClone5> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

""" .

<http://base_module.biographs.org/Mb1_module_port-subjectClone5> a smodule:ModulePortURI ;
    rdfs:label "Subject" ;
    rdfs:domain rdfs:Resource ;
    smodule:isSelected false ;
    smodule:variableName "?subjectClone5" .
    
<http://base_module.biographs.org/Mb1_module_port-valueClone5> a smodule:ModulePortTyped ;
    rdfs:label "value" ;
    rdfs:domain rdfs:Resource ;
    smodule:isSelected true ;
    smodule:variableName "?valueClone5" .

