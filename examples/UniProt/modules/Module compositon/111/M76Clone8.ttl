@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M76_moduleClone8> a smodule:SPARQLModule ;
    rdfs:label "faldo: start/end position and reference" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M76_module> ;
    smodule:fragmentSPARQL """
    ?entryClone8 faldo:begin ?faldoBeginClone8.
    ?faldoBeginClone8 faldo:position ?beginPositionClone8.
    ?faldoBeginClone8 faldo:reference ?referenceClone8.
    ?entryClone8 faldo:end ?faldoEndClone8.
    ?faldoEndClone8 faldo:position ?endPositionClone8.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M76_module_port-beginPositionClone8>,
        <http://uniprot_module.biographs.org/M76_module_port-endPositionClone8>,
        <http://uniprot_module.biographs.org/M76_module_port-entryClone8>,
        <http://uniprot_module.biographs.org/M76_module_port-faldoBeginClone8>,
        <http://uniprot_module.biographs.org/M76_module_port-faldoEndClone8>,
        <http://uniprot_module.biographs.org/M76_module_port-referenceClone8> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX faldo: <http://biohackathon.org/resource/faldo#>

""" .

<http://uniprot_module.biographs.org/M76_module_port-beginPositionClone8> a smodule:ModulePortURI ;
    rdfs:label "Begin Position" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected true ;
    smodule:variableName "?beginPositionClone8" .

<http://uniprot_module.biographs.org/M76_module_port-endPositionClone8> a smodule:ModulePortURI ;
    rdfs:label "End Position" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected true ;
    smodule:variableName "?endPositionClone8" .

<http://uniprot_module.biographs.org/M76_module_port-entryClone8> a smodule:ModulePortURI ;
    rdfs:label "Entry" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?entryClone8" .

<http://uniprot_module.biographs.org/M76_module_port-faldoBeginClone8> a smodule:ModulePortURI ;
    rdfs:label "FALDO begin" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?faldoBeginClone8" .

<http://uniprot_module.biographs.org/M76_module_port-faldoEndClone8> a smodule:ModulePortURI ;
    rdfs:label "FALDO end" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?faldoEndClone8" .

<http://uniprot_module.biographs.org/M76_module_port-referenceClone8> a smodule:ModulePortURI ;
    rdfs:label "Reference" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?referenceClone8" .

