@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M73_moduleClone7> a smodule:SPARQLModule ;
    rdfs:label "protein to gene" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M73_module> ;
    smodule:fragmentSPARQL """
    ?proteinClone7 rdf:type up:Protein.
    ?proteinClone7 up:encodedBy ?geneClone7.
    ?geneClone7 skos:prefLabel ?nameClone7.
    OPTIONAL {?geneClone7 up:locusName ?locusNameClone7.}
    OPTIONAL {?geneClone7 skos:altLabel ?altLabelClone7.}
    OPTIONAL {?geneClone7 up:orfName ?orfNameClone7.}
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M73_module_port-altLabelClone7>,
        <http://uniprot_module.biographs.org/M73_module_port-geneClone7>,
        <http://uniprot_module.biographs.org/M73_module_port-locusNameClone7>,
        <http://uniprot_module.biographs.org/M73_module_port-orfNameClone7>,
        <http://uniprot_module.biographs.org/M73_module_port-proteinClone7> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M73_module_port-altLabelClone7> a smodule:ModulePortDatatype ;
    rdfs:label "Alternative label" ;
    rdfs:domain xsd:string ;
    smodule:isSelected true ;
    smodule:variableName "?altLabelClone7" .

<http://uniprot_module.biographs.org/M73_module_port-geneClone7> a smodule:ModulePortURI ;
    rdfs:label "Gene" ;
    rdfs:domain up:Gene ;
    smodule:isSelected true ;
    smodule:variableName "?geneClone7" .

<http://uniprot_module.biographs.org/M73_module_port-locusNameClone7> a smodule:ModulePortDatatype ;
    rdfs:label "Locus name" ;
    rdfs:domain xsd:string ;
    smodule:isSelected true ;
    smodule:variableName "?locusNameClone7" .

<http://uniprot_module.biographs.org/M73_module_port-orfNameClone7> a smodule:ModulePortDatatype ;
    rdfs:label "ORF name" ;
    rdfs:domain xsd:string ;
    smodule:isSelected true ;
    smodule:variableName "?orfNameClone7" .

<http://uniprot_module.biographs.org/M73_module_port-proteinClone7> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:Protein ;
    smodule:isSelected true ;
    smodule:variableName "?proteinClone7" .

