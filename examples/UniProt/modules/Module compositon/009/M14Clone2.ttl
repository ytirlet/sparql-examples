@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M14_moduleClone2> a smodule:SPARQLModule ;
    rdfs:label "Protein annotation" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M14_module> ;
    smodule:fragmentSPARQL """ 
    ?proteinClone2 rdf:type up:Protein.
    ?proteinClone2 up:annotation ?annotationClone2.
    ?annotationClone2 rdf:type ?annotationTypeClone2.
    ?annotationClone2 rdfs:comment ?commentClone2.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M14_module_port-annotationClone2>,
        <http://uniprot_module.biographs.org/M14_module_port-annotationTypeClone2>,
        <http://uniprot_module.biographs.org/M14_module_port-commentClone2>,
        <http://uniprot_module.biographs.org/M14_module_port-proteinClone2> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M14_module_port-annotationClone2> a smodule:ModulePortURI ;
    rdfs:label "Annotation" ;
    rdfs:domain up:Annotation ;
    smodule:isSelected false ;
    smodule:variableName "?annotationClone2" .

<http://uniprot_module.biographs.org/M14_module_port-annotationTypeClone2> a smodule:ModulePortURI ;
    rdfs:label "Type of annotation" ;
    rdfs:domain up:Annotation ;
    smodule:isSelected false ;
    smodule:variableName "?annotationTypeClone2" .

<http://uniprot_module.biographs.org/M14_module_port-commentClone2> a smodule:ModulePortDatatype ;
    rdfs:label "Annotation comment" ;
    rdfs:domain xsd:string ;
    smodule:isSelected true ;
    smodule:variableName "?commentClone2" .

<http://uniprot_module.biographs.org/M14_module_port-proteinClone2> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:Protein ;
    smodule:isSelected true ;
    smodule:variableName "?proteinClone2" .

