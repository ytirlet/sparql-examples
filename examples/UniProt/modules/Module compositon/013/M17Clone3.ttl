@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M17_moduleClone3> a smodule:SPARQLModule ;
    rdfs:label "Protein information" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M17_module> ;
    smodule:fragmentSPARQL """
    ?proteinClone3 rdf:type up:Protein ;
      up:created ?creationDateClone3 ;
      up:modified ?modificationDateClone3 ;
      up:reviewed ?reviewedClone3 ;
      up:version ?versionClone3 .
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M17_module_port-creationDateClone3>,
        <http://uniprot_module.biographs.org/M17_module_port-modificationDateClone3>,
        <http://uniprot_module.biographs.org/M17_module_port-proteinClone3>,
        <http://uniprot_module.biographs.org/M17_module_port-reviewedClone3>,
        <http://uniprot_module.biographs.org/M17_module_port-versionClone3> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M17_module_port-creationDateClone3> a smodule:ModulePortURI ;
    rdfs:label "date of creation" ;
    rdfs:domain xsd:date ;
    smodule:isSelected false ;
    smodule:variableName "?creationDateClone3" .

<http://uniprot_module.biographs.org/M17_module_port-modificationDateClone3> a smodule:ModulePortDatatype ;
    rdfs:label "date of modification" ;
    rdfs:domain xsd:date ;
    smodule:isSelected false ;
    smodule:variableName "?modificationDateClone3" .

<http://uniprot_module.biographs.org/M17_module_port-proteinClone3> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:Protein ;
    smodule:isSelected true ;
    smodule:variableName "?proteinClone3" .

<http://uniprot_module.biographs.org/M17_module_port-reviewedClone3> a smodule:ModulePortDatatype ;
    rdfs:label "is reviewed" ;
    rdfs:domain xsd:boolean ;
    smodule:isSelected false ;
    smodule:variableName "?reviewedClone3" .

<http://uniprot_module.biographs.org/M17_module_port-versionClone3> a smodule:ModulePortDatatype ;
    rdfs:label "Version" ;
    rdfs:domain xsd:int ;
    smodule:isSelected false ;
    smodule:variableName "?versionClone3" .

