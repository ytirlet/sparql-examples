@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

up_mod:M32_moduleClone2 a smodule:SPARQLModule;
  rdfs:label "Entry sequence"@en;
  rdfs:comment "Entry sequence"@en;
  smodule:clonedFrom <http://uniprot_module.biographs.org/M32_module> ;
  schema:keywords "sequence";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
    """ ;
  smodule:fragmentSPARQL """
    ?entryClone2 rdf:type ?entryTypeClone2.
    ?entryClone2 up:sequence ?sequenceClone2.
    ?sequenceClone2 rdf:type ?sequenceTypeClone2.
    ?sequenceClone2 rdf:value ?valueClone2.
    """;
  smodule:output up_mod:M32_module_port-entryClone2, up_mod:M32_module_port-entryTypeClone2, up_mod:M32_module_port-sequenceClone2 , up_mod:M32_module_port-sequenceTypeClone2, up_mod:M32_module_port-valueClone2.

up_mod:M32_module_port-entryClone2
  a smodule:ModulePortURI;
  rdfs:domain [
		a owl:Class ;
		smodule:option (up:Annotation up:Resource up:Protein)
		]; 
  smodule:variableName "?entryClone2" ;
  rdfs:label "Entry" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M32_module_port-sequenceClone2
  a smodule:ModulePortURI;
  smodule:variableName "?sequenceClone2" ;
  rdfs:label "Sequence" ;
  smodule:isSelected "false"^^xsd:boolean.

up_mod:M32_module_port-entryTypeClone2
  a smodule:ModulePortURI;
  smodule:option (up:Annotation up:Ressource up:Protein) ;
  smodule:variableName "?entryTypeClone2" ;
  rdfs:label "Entry type" ;
  smodule:isSelected "false"^^xsd:boolean.
  
up_mod:M32_module_port-sequenceTypeClone2
  a smodule:ModulePortURI;
  smodule:variableName "?sequenceTypeClone2" ;
  rdfs:label "Sequence type" ;
  smodule:isSelected "false"^^xsd:boolean.
  
up_mod:M32_module_port-valueClone2
  a smodule:ModulePortDatatype;
  rdfs:domain xsd:string;
  smodule:variableName "?valueClone2" ;
  rdfs:label "Value" ;
  smodule:isSelected "false"^^xsd:boolean.
