smodule:module_composition_081 dcterms:title "Find all Rhea (only small molecule) that are used in UniProtKB where the annotation has a paper and is tagged having experimental evidence".
smodule:module_composition_081 rdfs:comment "Find all Rhea (only small molecule) that are used in UniProtKB where the annotation has a paper and is tagged having experimental evidence".
smodule:module_composition_081 dcterms:subject "small molecule", "Rhea", "evidence tag".

smodule:module_composition_081 rdf:type smodule:SPARQL_Module_Composition.
smodule:module_composition_081 smodule:hasConnection smodule:081_c1 , smodule:081_c2, smodule:081_c3, smodule:081_c4, smodule:081_c5, smodule:081_c6, smodule:081_c7.
smodule:module_composition_081 smodule:hasComponent smodule:OperatorValuesClone112, smodule:OperatorValuesClone111, smodule:OperatorValuesClone110, smodule:OperatorServiceClone9, up_mod:M38_moduleClone12, base_mod:Mb6_moduleClone1, up_mod:M39_moduleClone22, up_mod:M20_moduleClone5.
smodule:module_composition_081 smodule:includeFile "VALUESClone112.ttl", "VALUESClone111.ttl", "VALUESClone110.ttl", "SERVICEClone9.ttl", "M38Clone12.ttl", "Mb6Clone1.ttl", "M39Clone22.ttl", "M20Clone5.ttl".

