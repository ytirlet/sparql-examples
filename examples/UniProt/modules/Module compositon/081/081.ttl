smodule:OperatorServicePortResultClone9 smodule:serviceInput "<https://sparql.rhea-db.org/sparql>".

smodule:081_c3 rdf:type smodule:Connection.
smodule:081_c3 smodule:connects up_mod:M38_module_port-compoundClone12, base_mod:Mb6_module_port-subjectClone1.

