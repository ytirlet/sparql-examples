@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M20_moduleClone5> a smodule:SPARQLModule ;
    rdfs:label "Annotation attribution" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M20_module> ;
    smodule:fragmentSPARQL """
    ?objectClone5 rdf:object ?annotationClone5.
    ?objectClone5 up:attribution ?attributionClone5.
    ?attributionClone5 up:source ?sourceClone5.
    ?sourceClone5 rdf:type ?sourceTypeClone5.
    ?attributionClone5 up:evidence ?evidenceClone5.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M20_module_port-annotationClone5>,
        <http://uniprot_module.biographs.org/M20_module_port-attributionClone5>,
        <http://uniprot_module.biographs.org/M20_module_port-evidenceClone5>,
        <http://uniprot_module.biographs.org/M20_module_port-objectClone5>,
        <http://uniprot_module.biographs.org/M20_module_port-sourceClone5>,
        <http://uniprot_module.biographs.org/M20_module_port-sourceTypeClone5> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M20_module_port-annotationClone5> a smodule:ModulePortURI ;
    rdfs:label "Annotation" ;
    rdfs:domain up:Annotation ;
    smodule:isSelected false ;
    smodule:variableName "?annotationClone5" .

<http://uniprot_module.biographs.org/M20_module_port-attributionClone5> a smodule:ModulePortURI ;
    rdfs:label "Attribution" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?attributionClone5" .

<http://uniprot_module.biographs.org/M20_module_port-evidenceClone5> a smodule:ModulePortURI ;
    rdfs:label "Evidence" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?evidenceClone5" .

<http://uniprot_module.biographs.org/M20_module_port-objectClone5> a smodule:ModulePortURI ;
    rdfs:label "Object" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?objectClone5" .

<http://uniprot_module.biographs.org/M20_module_port-sourceClone5> a smodule:ModulePortURI ;
    rdfs:label "Source" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected true ;
    smodule:variableName "?sourceClone5" .

<http://uniprot_module.biographs.org/M20_module_port-sourceTypeClone5> a smodule:ModulePortURI ;
    rdfs:label "Source type" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?sourceTypeClone5" .

