@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix base_mod: <http://base_module.biographs.org/> .

<http://base_module.biographs.org/Mb6_moduleClone1> a smodule:SPARQLModule ;
    rdfs:label "rdfs sub class of" ;
    smodule:clonedFrom <http://base_module.biographs.org/Mb6_module> ;
    smodule:fragmentSPARQL """ 
    ?subjectClone1 rdfs:subClassOf ?classClone1 .
    """ ;
    smodule:output <http://base_module.biographs.org/Mb6_module_port-subjectClone1>, base_mod:Mb6_module_port-classClone1 ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

""" .

<http://base_module.biographs.org/Mb6_module_port-subjectClone1> a smodule:ModulePortURI ;
    rdfs:label "Subject" ;
    rdfs:domain rdfs:Resource ;
    smodule:isSelected false ;
    smodule:variableName "?subjectClone1" .
    
base_mod:Mb6_module_port-classClone1
  a smodule:ModulePortTyped;
  rdfs:domain rdfs:Resource;
  smodule:variableName "?classClone1" ;
  rdfs:label "class" ;
  smodule:isSelected "false"^^xsd:boolean .

