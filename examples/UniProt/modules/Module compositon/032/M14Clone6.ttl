@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M14_moduleClone6> a smodule:SPARQLModule ;
    rdfs:label "Protein annotation" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M14_module> ;
    smodule:fragmentSPARQL """ 
    ?proteinClone6 rdf:type up:Protein.
    ?proteinClone6 up:annotation ?annotationClone6.
    ?annotationClone6 rdf:type ?annotationTypeClone6.
    ?annotationClone6 rdfs:comment ?commentClone6.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M14_module_port-annotationClone6>,
        <http://uniprot_module.biographs.org/M14_module_port-annotationTypeClone6>,
        <http://uniprot_module.biographs.org/M14_module_port-commentClone6>,
        <http://uniprot_module.biographs.org/M14_module_port-proteinClone6> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M14_module_port-annotationClone6> a smodule:ModulePortURI ;
    rdfs:label "Annotation" ;
    rdfs:domain up:Annotation ;
    smodule:isSelected false ;
    smodule:variableName "?annotationClone6" .

<http://uniprot_module.biographs.org/M14_module_port-annotationTypeClone6> a smodule:ModulePortURI ;
    rdfs:label "Type of annotation" ;
    rdfs:domain up:Annotation ;
    smodule:isSelected false ;
    smodule:variableName "?annotationTypeClone6" .

<http://uniprot_module.biographs.org/M14_module_port-commentClone6> a smodule:ModulePortDatatype ;
    rdfs:label "Annotation comment" ;
    rdfs:domain xsd:string ;
    smodule:isSelected true ;
    smodule:variableName "?commentClone6" .

<http://uniprot_module.biographs.org/M14_module_port-proteinClone6> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:Protein ;
    smodule:isSelected true ;
    smodule:variableName "?proteinClone6" .

