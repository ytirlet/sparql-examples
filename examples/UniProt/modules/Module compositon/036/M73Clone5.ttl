@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M73_moduleClone5> a smodule:SPARQLModule ;
    rdfs:label "protein to gene" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M73_module> ;
    smodule:fragmentSPARQL """
    ?proteinClone5 rdf:type up:Protein.
    ?proteinClone5 up:encodedBy ?geneClone5.
    ?geneClone5 skos:prefLabel ?nameClone5.
    OPTIONAL {?geneClone5 up:locusName ?locusNameClone5.}
    OPTIONAL {?geneClone5 skos:altLabel ?altLabelClone5.}
    OPTIONAL {?geneClone5 up:orfName ?orfNameClone5.}
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M73_module_port-altLabelClone5>,
        <http://uniprot_module.biographs.org/M73_module_port-geneClone5>,
        <http://uniprot_module.biographs.org/M73_module_port-locusNameClone5>,
        <http://uniprot_module.biographs.org/M73_module_port-orfNameClone5>,
        <http://uniprot_module.biographs.org/M73_module_port-proteinClone5>,
        <http://uniprot_module.biographs.org/M73_module_port-nameClone5> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M73_module_port-altLabelClone5> a smodule:ModulePortDatatype ;
    rdfs:label "Alternative label" ;
    rdfs:domain xsd:string ;
    smodule:isSelected false ;
    smodule:variableName "?altLabelClone5" .

<http://uniprot_module.biographs.org/M73_module_port-geneClone5> a smodule:ModulePortURI ;
    rdfs:label "Gene" ;
    rdfs:domain up:Gene ;
    smodule:isSelected false ;
    smodule:variableName "?geneClone5" .

<http://uniprot_module.biographs.org/M73_module_port-locusNameClone5> a smodule:ModulePortDatatype ;
    rdfs:label "Locus name" ;
    rdfs:domain xsd:string ;
    smodule:isSelected false ;
    smodule:variableName "?locusNameClone5" .

<http://uniprot_module.biographs.org/M73_module_port-orfNameClone5> a smodule:ModulePortDatatype ;
    rdfs:label "ORF name" ;
    rdfs:domain xsd:string ;
    smodule:isSelected false ;
    smodule:variableName "?orfNameClone5" .

<http://uniprot_module.biographs.org/M73_module_port-proteinClone5> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:Protein ;
    smodule:isSelected true ;
    smodule:variableName "?proteinClone5" .
    
<http://uniprot_module.biographs.org/M73_module_port-nameClone5> a smodule:ModulePortDatatype ;
    rdfs:label "Name" ;
    rdfs:domain xsd:string ;
    smodule:isSelected true ;
    smodule:variableName "?nameClone5" .

