@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rh: <http://rdf.rhea-db.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/m7_moduleClone2> a smodule:SPARQLModule ;
    rdfs:label "englishLabelStr structured name" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/m7_module> ;
    smodule:fragmentSPARQL """ 
    ?reactionClone2 rdfs:subClassOf rh:Reaction ;
      rh:equation ?equationClone2 .
    """ ;
    smodule:output <http://uniprot_module.biographs.org/m7_module_port-equationClone2>,
        <http://uniprot_module.biographs.org/m7_module_port-reactionClone2> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX rh: <http://rdf.rhea-db.org/>

""" .

<http://uniprot_module.biographs.org/m7_module_port-equationClone2> a smodule:ModulePortURI ;
    rdfs:label "equation" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?equationClone2" .

<http://uniprot_module.biographs.org/m7_module_port-reactionClone2> a smodule:ModulePortURI ;
    rdfs:label "Reaction" ;
    rdfs:domain rh:Reaction ;
    smodule:isSelected true ;
    smodule:variableName "?reactionClone2" .

