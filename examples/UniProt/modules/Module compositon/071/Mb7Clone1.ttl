@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix base_mod: <http://base_module.biographs.org/> .

<http://base_module.biographs.org/Mb7_moduleClone1> a smodule:SPARQLModule ;
    rdfs:label "skos related" ;
    smodule:clonedFrom <http://base_module.biographs.org/Mb7_module> ;
    smodule:fragmentSPARQL """ 
    ?subjectClone1 skos:related ?objectClone1 .
    """ ;
    smodule:output <http://base_module.biographs.org/Mb7_module_port-subjectClone1> , base_mod:Mb7_module_port-objectClone1 ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

""" .

<http://base_module.biographs.org/Mb7_module_port-subjectClone1> a smodule:ModulePortURI ;
    rdfs:label "Subject" ;
    rdfs:domain rdfs:Resource ;
    smodule:isSelected false ;
    smodule:variableName "?subjectClone1" .

base_mod:Mb7_module_port-objectClone1
  a smodule:ModulePortTyped;
  rdfs:domain rdfs:Resource;
  smodule:variableName "?objectClone1" ;
  rdfs:label "object" ;
  smodule:isSelected "true"^^xsd:boolean .
