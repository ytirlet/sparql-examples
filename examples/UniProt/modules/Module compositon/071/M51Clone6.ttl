@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M51_moduleClone6> a smodule:SPARQLModule ;
    rdfs:label "protein and associated disease" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M51_module> ;
    smodule:fragmentSPARQL """
    ?proteinClone6 up:annotation ?annotationClone6.
    ?proteinClone6 rdf:type up:Protein.
    ?annotationClone6 rdf:type up:Disease_Annotation.
    ?annotationClone6 up:disease ?diseaseClone6.
    ?diseaseClone6 skos:prefLabel ?diseaseLabelClone6.
    ?diseaseClone6 rdf:type up:Disease.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M51_module_port-annotationClone6>,
        <http://uniprot_module.biographs.org/M51_module_port-diseaseClone6>,
        <http://uniprot_module.biographs.org/M51_module_port-diseaseLabelClone6>,
        <http://uniprot_module.biographs.org/M51_module_port-proteinClone6> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M51_module_port-annotationClone6> a smodule:ModulePortURI ;
    rdfs:label "Annotation" ;
    rdfs:domain up:Disease_Annotation ;
    smodule:isSelected false ;
    smodule:variableName "?annotationClone6" .

<http://uniprot_module.biographs.org/M51_module_port-diseaseClone6> a smodule:ModulePortURI ;
    rdfs:label "Disease" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected true ;
    smodule:variableName "?diseaseClone6" .

<http://uniprot_module.biographs.org/M51_module_port-diseaseLabelClone6> a smodule:ModulePortDatatype ;
    rdfs:label "Disease label" ;
    rdfs:domain xsd:string ;
    smodule:isSelected false ;
    smodule:variableName "?diseaseLabelClone6" .

<http://uniprot_module.biographs.org/M51_module_port-proteinClone6> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:Protein ;
    smodule:isSelected true ;
    smodule:variableName "?proteinClone6" .

