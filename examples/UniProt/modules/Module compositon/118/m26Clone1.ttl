@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:m26_moduleClone1 a smodule:SPARQLModule;
  rdfs:label "englishLabelStr structured name"@en;
  rdfs:comment "englishLabelStr structured name"@en;
  smodule:clonedFrom <http://uniprot_module.biographs.org/m26_module> ;
  schema:keywords "structured name";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  """ ;
  smodule:fragmentSPARQL """ 
  SERVICE <https://sparql.omabrowser.org/sparql/> {
    SELECT ?orthologous_protein2Clone1 ?protein1Clone1 ?geneClone1 WHERE {
      ?protein_OMAClone1 a orth:Protein .
      ?orthologous_protein2Clone1 a orth:Protein .
      ?clusterClone1 a orth:OrthologsCluster .
      ?clusterClone1 orth:hasHomologousMember ?node1Clone1 .
      ?clusterClone1 orth:hasHomologousMember ?node2Clone1 .
      ?node2Clone1 orth:hasHomologousMember* ?protein_OMAClone1 .
      ?node1Clone1 orth:hasHomologousMember* ?orthologous_protein2Clone1.
      ?orthologous_protein2Clone1 orth:organism/obo:RO_0002162/up:scientificName 'Rattus norvegicus' .
      ?orthologous_protein2Clone1 sio:SIO_010079 ?geneClone1 .
      ?protein_OMAClone1 lscr:xrefUniprot ?protein1Clone1 .
      FILTER(?node1Clone1 != ?node2Clone1)
    }
  }
  SERVICE <https://www.bgee.org/sparql/> {
    ?geneClone1 genex:isExpressedIn ?anatEntityClone1 .
    ?anatEntityClone1 rdfs:label 'brain' .
    ?geneClone1 orth:organism ?orgClone1 . 
    ?orgClone1 obo:RO_0002162 taxon:10116 .
  }
    """;
  smodule:output up_mod:m26_module_port-protein1Clone1.
  
up_mod:m26_module_port-protein1Clone1
  a smodule:ModulePortURI ;
  smodule:variableName "?protein1Clone1";
  rdfs:domain up:Protein ;
  rdfs:label "protein" ;
  smodule:isSelected "false"^^xsd:boolean.
