@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

<http://uniprot_module.biographs.org/M72_moduleClone8> a smodule:SPARQLModule ;
    rdfs:label "Entry Names" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M72_module> ;
    smodule:fragmentSPARQL """
    ?entryClone8 up:recommendedName ?recNameClone8.
    ?entryClone8 up:alternativeName ?altNameClone8.
    ?recNameClone8 up:fullName ?fullNameClone8.
    ?recNameClone8 up:shortName ?shortNameClone8.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M72_module_port-altNameClone8>,
        <http://uniprot_module.biographs.org/M72_module_port-fullNameClone8>,
        <http://uniprot_module.biographs.org/M72_module_port-recNameClone8>,
        <http://uniprot_module.biographs.org/M72_module_port-shortNameClone8>,
        up_mod:M72_module_port-entryClone8;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M72_module_port-altNameClone8> a smodule:ModulePortURI ;
    rdfs:label "Alternative Name" ;
    rdfs:domain up:Structured_Name ;
    smodule:isSelected true ;
    smodule:variableName "?altNameClone8" .

<http://uniprot_module.biographs.org/M72_module_port-fullNameClone8> a smodule:ModulePortURI ;
    rdfs:label "Full Name" ;
    rdfs:domain up:Structured_Name ;
    smodule:isSelected true ;
    smodule:variableName "?fullNameClone8" .

<http://uniprot_module.biographs.org/M72_module_port-recNameClone8> a smodule:ModulePortURI ;
    rdfs:label "Recommended Name" ;
    rdfs:domain up:Structured_Name ;
    smodule:isSelected true ;
    smodule:variableName "r?ecNameClone8" .

<http://uniprot_module.biographs.org/M72_module_port-shortNameClone8> a smodule:ModulePortURI ;
    rdfs:label "Short Name" ;
    rdfs:domain up:Structured_Name ;
    smodule:isSelected true ;
    smodule:variableName "?shortNameClone8" .

up_mod:M72_module_port-entryClone8
  a smodule:ModulePortURI;
  rdfs:domain [
		a owl:Class ;
		smodule:option (up:Protein up:Part)
		]; 
  smodule:variableName "?entryClone8" ;
  rdfs:label "Entry" ;
  smodule:isSelected "true"^^xsd:boolean.
