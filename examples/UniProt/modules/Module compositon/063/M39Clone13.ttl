@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M39_moduleClone13> a smodule:SPARQLModule ;
    rdfs:label "Protein to catalyzed reaction" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M39_module> ;
    smodule:fragmentSPARQL """
    ?proteinClone13 rdf:type up:Protein .
    ?proteinClone13 up:annotation ?annotationClone13.
    ?annotationClone13 up:catalyticActivity ?catalyticActivityClone13.
    ?catalyticActivityClone13 rdf:type up:Catalytic_Activity .
    ?catalyticActivityClone13 up:catalyzedReaction ?reactionClone13.
    ?annotationClone13 rdf:type up:Catalytic_Activity_Annotation.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M39_module_port-annotationClone13>,
        <http://uniprot_module.biographs.org/M39_module_port-catalyticActivityClone13>,
        <http://uniprot_module.biographs.org/M39_module_port-proteinClone13>,
        <http://uniprot_module.biographs.org/M39_module_port-reactionClone13> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX : <http://biographs.org/>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M39_module_port-annotationClone13> a smodule:ModulePortURI ;
    rdfs:label "Annotation" ;
    rdfs:domain up:Catalytic_Activity_Annotation ;
    smodule:isSelected false ;
    smodule:variableName "?annotationClone13" .

<http://uniprot_module.biographs.org/M39_module_port-catalyticActivityClone13> a smodule:ModulePortURI ;
    rdfs:label "Catalytic Activity" ;
    rdfs:domain up:Catalytic_Activity ;
    smodule:isSelected false ;
    smodule:variableName "?catalyticActivityClone13" .

<http://uniprot_module.biographs.org/M39_module_port-proteinClone13> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:Protein ;
    smodule:isSelected true ;
    smodule:variableName "?proteinClone13" .

<http://uniprot_module.biographs.org/M39_module_port-reactionClone13> a smodule:ModulePortURI ;
    rdfs:label "Reaction" ;
    rdfs:domain <http://rdf.rhea-db.org/Reaction> ;
    smodule:isSelected false ;
    smodule:variableName "?reactionClone13" .

