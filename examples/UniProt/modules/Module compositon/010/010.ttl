smodule:010_c3 smodule:connects up_mod:M40_module_port-rangeClone1, up_mod:M76_module_port-entryClone1.

smodule:010_c4 rdf:type smodule:Connection.
smodule:010_c4 smodule:connects up_mod:M40_module_port-annotationClone1, up_mod:M79_module_port-annotationClone1.

smodule:010_c5 rdf:type smodule:Connection.
smodule:010_c5 smodule:connects up_mod:M67_module_port-organismClone4, smodule:OperatorValuesPortResultClone12.

smodule:OperatorValuesPortResultClone12 smodule:valuesEnumeration "taxon:9606" .

smodule:010_c6 rdf:type smodule:Connection.
smodule:010_c6 smodule:connects up_mod:M79_module_port-substitutionClone1, smodule:OperatorValuesPortResultClone11.

