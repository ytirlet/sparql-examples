smodule:module_composition_010 dcterms:title "Select all human UniProtKB entries with a sequence variant that leads to a tyrosine to phenylalanine substitution".
smodule:module_composition_010 rdfs:comment "Select all human UniProtKB entries with a sequence variant that leads to a tyrosine to phenylalanine substitution".
smodule:module_composition_010 dcterms:subject "variant annotation", "search within sequence".

smodule:module_composition_010 rdf:type smodule:SPARQL_Module_Composition.
smodule:module_composition_010 smodule:hasConnection smodule:010_c1 , smodule:010_c2, smodule:010_c3, smodule:010_c4, smodule:010_c5, smodule:010_c6, smodule:010_c8. #, smodule:010_c9.smodule:010_c7,
smodule:module_composition_010 smodule:hasComponent smodule:OperatorValuesClone12, smodule:OperatorValuesClone11, up_mod:M76_moduleClone1, base_mod:Mb1_moduleClone1, up_mod:M79_moduleClone1, up_mod:M67_moduleClone4, up_mod:M40_moduleClone1.
smodule:module_composition_010 smodule:includeFile "VALUESClone12.ttl", "VALUESClone11.ttl", "M76Clone1.ttl", "Mb1Clone1.ttl", "M79Clone1.ttl", "M67Clone4.ttl", "M40Clone1.ttl".

