@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M79_moduleClone1> a smodule:SPARQLModule ;
    rdfs:label "Natural Variant Annotation" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M79_module> ;
    smodule:fragmentSPARQL """ 
    ?proteinClone1 rdf:type up:Protein.
    ?proteinClone1 up:annotation ?annotationClone1.
    ?annotationClone1 rdf:type up:Natural_Variant_Annotation.
    ?annotationClone1 rdfs:comment ?commentClone1.
    ?annotationClone1 up:substitution ?substitutionClone1.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M79_module_port-annotationClone1>,
        <http://uniprot_module.biographs.org/M79_module_port-commentClone1>,
        <http://uniprot_module.biographs.org/M79_module_port-proteinClone1>,
        <http://uniprot_module.biographs.org/M79_module_port-substitutionClone1> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M79_module_port-annotationClone1> a smodule:ModulePortURI ;
    rdfs:label "Annotation" ;
    rdfs:domain up:Annotation ;
    smodule:isSelected false ;
    smodule:variableName "?annotationClone1" .

<http://uniprot_module.biographs.org/M79_module_port-commentClone1> a smodule:ModulePortDatatype ;
    rdfs:label "Annotation comment" ;
    rdfs:domain xsd:string ;
    smodule:isSelected false ;
    smodule:variableName "?commentClone1" .

<http://uniprot_module.biographs.org/M79_module_port-proteinClone1> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:Protein ;
    smodule:isSelected true ;
    smodule:variableName "?proteinClone1" .

<http://uniprot_module.biographs.org/M79_module_port-substitutionClone1> a smodule:ModulePortDatatype ;
    rdfs:label "Substitution" ;
    rdfs:domain xsd:string ;
    smodule:isSelected false ;
    smodule:variableName "?substitutionClone1" .

