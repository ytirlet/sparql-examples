@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rh: <http://rdf.rhea-db.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M75_moduleClone2> a smodule:SPARQLModule ;
    rdfs:label "compound to ChEBI" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M75_module> ;
    smodule:fragmentSPARQL """
    ?compoundClone2 (rh:chebi|(rh:reactivePart/rh:chebi)|(rh:underlyingChebi)) ?chebiClone2 .
    ?chebiClone2 (rdfs:subClassOf)+ ?chebiAncestorClone2.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M75_module_port-chebiAncestorClone2>,
        <http://uniprot_module.biographs.org/M75_module_port-chebiClone2>,
        <http://uniprot_module.biographs.org/M75_module_port-compoundClone2> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX : <http://biographs.org/>
PREFIX rh: <http://rdf.rhea-db.org/>

""" .

<http://uniprot_module.biographs.org/M75_module_port-chebiAncestorClone2> a smodule:ModulePortURI ;
    rdfs:label "Ancestor ChEBI" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?chebiAncestorClone2" .

<http://uniprot_module.biographs.org/M75_module_port-chebiClone2> a smodule:ModulePortURI ;
    rdfs:label "ChEBI" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?chebiClone2" .

<http://uniprot_module.biographs.org/M75_module_port-compoundClone2> a smodule:ModulePortURI ;
    rdfs:label "Compound" ;
    rdfs:domain rh:Compound ;
    smodule:isSelected false ;
    smodule:variableName "?compoundClone2" .

