@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

<http://uniprot_module.biographs.org/M67_moduleClone38> a smodule:SPARQLModule ;
    rdfs:label "Entry to taxon" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M67_module> ;
    smodule:fragmentSPARQL """
    ?entryClone38 up:organism ?organismClone38.
    ?organismClone38 rdfs:subClassOf? ?taxonClone38. # Hierarchy of taxon is materialized
    """ ;
    smodule:output up_mod:M67_module_port-taxonClone38, up_mod:M67_module_port-entryClone38, up_mod:M67_module_port-organismClone38 ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>
""" .

up_mod:M67_module_port-taxonClone38 a smodule:ModulePortTyped ;
    rdfs:label "taxon" ;
    rdfs:domain xsd:any ;
    smodule:isSelected false ;
    smodule:variableName "?taxonClone38" .

up_mod:M67_module_port-organismClone38 a smodule:ModulePortTyped ;
    rdfs:label "organism" ;
    rdfs:domain xsd:any ;
    smodule:isSelected false ;
    smodule:variableName "?organismClone38" .

up_mod:M67_module_port-entryClone38 a smodule:ModulePortTyped ;
    rdfs:label "entry" ;
    rdfs:domain xsd:any ;
    smodule:isSelected true ;
    smodule:variableName "?entryClone38" .

