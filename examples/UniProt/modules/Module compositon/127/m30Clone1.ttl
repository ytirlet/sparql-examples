@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/m30_moduleClone1> a smodule:SPARQLModule ;
    rdfs:label "englishLabelStr structured name" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/m30_module> ;
    smodule:fragmentSPARQL """ 
    BIND((CONCAT('chebi:',SUBSTR(STR(?chebiClone1), STRLEN(STR(CHEBI:))+1))) AS ?chebiIdClone1)
    """ ;
    smodule:output <http://uniprot_module.biographs.org/m30_module_port-chebIdClone1>,
        <http://uniprot_module.biographs.org/m30_module_port-chebiClone1> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

""" .

<http://uniprot_module.biographs.org/m30_module_port-chebIdClone1> a smodule:ModulePortURI ;
    rdfs:label "chebId" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected true ;
    smodule:variableName "?chebIdClone1" .

<http://uniprot_module.biographs.org/m30_module_port-chebiClone1> a smodule:ModulePortURI ;
    rdfs:label "chebi" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?chebiClone1" .

