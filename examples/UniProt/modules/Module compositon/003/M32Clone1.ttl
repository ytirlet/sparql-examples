@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

up_mod:M32_moduleClone1 a smodule:SPARQLModule;
  rdfs:label "Entry sequence"@en;
  rdfs:comment "Entry sequence"@en;
  smodule:clonedFrom <http://uniprot_module.biographs.org/M32_module> ;
  schema:keywords "sequence";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
    """ ;
  smodule:fragmentSPARQL """
    ?entryClone1 rdf:type ?entryTypeClone1.
    ?entryClone1 up:sequence ?sequenceClone1.
    ?sequenceClone1 rdf:type ?sequenceTypeClone1.
    ?sequenceClone1 rdf:value ?valueClone1.
    """;
  smodule:output up_mod:M32_module_port-entryClone1, up_mod:M32_module_port-entryTypeClone1, up_mod:M32_module_port-sequenceClone1 , up_mod:M32_module_port-sequenceTypeClone1, up_mod:M32_module_port-valueClone1.

up_mod:M32_module_port-entryClone1
  a smodule:ModulePortURI;
  rdfs:domain [
		a owl:Class ;
		smodule:option (up:Annotation up:Resource up:Protein)
		]; 
  smodule:variableName "?entryClone1" ;
  rdfs:label "Entry" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M32_module_port-sequenceClone1
  a smodule:ModulePortURI;
  smodule:variableName "?sequenceClone1" ;
  rdfs:label "Sequence" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M32_module_port-entryTypeClone1
  a smodule:ModulePortURI;
  smodule:option (up:Annotation up:Ressource up:Protein) ;
  smodule:variableName "?entryTypeClone1" ;
  rdfs:label "Entry type" ;
  smodule:isSelected "false"^^xsd:boolean.
  
up_mod:M32_module_port-sequenceTypeClone1
  a smodule:ModulePortURI;
  smodule:variableName "?sequenceTypeClone1" ;
  rdfs:label "Sequence type" ;
  smodule:isSelected "false"^^xsd:boolean.
  
up_mod:M32_module_port-valueClone1
  a smodule:ModulePortDatatype;
  rdfs:domain xsd:string;
  smodule:variableName "?valueClone1" ;
  rdfs:label "Value" ;
  smodule:isSelected "true"^^xsd:boolean.
