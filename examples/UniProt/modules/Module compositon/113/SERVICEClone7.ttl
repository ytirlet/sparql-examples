@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

smodule:OperatorServiceClone7 a smodule:SPARQLModuleOperatorService ;
    rdfs:label "Operator SERVICE" ;
    smodule:clonedFrom smodule:moduleOperatorSERVICE;
    smodule:fragmentSPARQL """
  SERVICE <https://sparql.rhea-db.org/sparql> {
  # Result variable is ?operatorServiceResult
  [operatorParameter0]
  } .
""" ;
    smodule:output smodule:OperatorServicePortParameterClone7,
        smodule:OperatorServicePortResultClone7 ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

""" .

smodule:OperatorServicePortParameterClone7 a smodule:ModulePortOperatorParameter ;
    rdfs:label "Parameter" ;
    smodule:isSelected false ;
    smodule:variableName "[operatorParameter0]" .

smodule:OperatorServicePortResultClone7 a smodule:ModulePortTyped ;
    rdfs:label "Result" ;
    rdfs:domain xsd:any ;
    smodule:isSelected false ;
    smodule:variableName "?operatorServiceResult" .

