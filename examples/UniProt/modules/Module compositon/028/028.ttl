smodule:module_composition_028 rdf:type smodule:SPARQL_Module_Composition.
smodule:module_composition_028 smodule:hasConnection smodule:028_c1 , smodule:028_c2, smodule:028_c3.
smodule:module_composition_028 smodule:hasComponent smodule:OperatorValuesClone36, smodule:OperatorValuesClone35, up_mod:M77_moduleClone1, up_mod:M17_moduleClone5.
