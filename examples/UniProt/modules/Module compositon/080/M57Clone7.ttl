@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

up_mod:M57_moduleClone7 a smodule:SPARQLModule ;
  rdfs:label "entry mnemonic"@en ;
  rdfs:comment "entry mnemonic"@en ;
  smodule:clonedFrom <http://uniprot_module.biographs.org/M57_module> ;
  schema:keywords "mnemonic" ;
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
    """ ;
  smodule:fragmentSPARQL """
    ?entryClone7 rdf:type ?typeClone7.
    ?entryClone7 up:mnemonic ?mnemonicClone7.
    OPTIONAL {?entryClone7 up:oldMnemonic ?oldmnemonicClone7.}
    """ ;
  smodule:output up_mod:M57_module_port-entryClone7, up_mod:M57_module_port-typeClone7, up_mod:M57_module_port-mnemonicClone7, up_mod:M57_module_port-oldmnemonicClone7 .
    
up_mod:M57_module_port-entryClone7
  a smodule:ModulePortURI ; 
  smodule:variableName "?entryClone7" ; 
  rdfs:domain [
    a owl:Class ;
    smodule:option (up:Cluster up:Protein up:Sequence)
    ]; 
  rdfs:label "Entry" ;
  smodule:isSelected "true"^^xsd:boolean.
	
up_mod:M57_module_port-typeClone7
  a smodule:ModulePortURI ; 
  smodule:variableName "?typeClone7" ;
  smodule:option (up:Cluster up:Protein up:Sequence) ;
  rdfs:label "Entry type" ;
  smodule:isSelected "true"^^xsd:boolean.
	
up_mod:M57_module_port-mnemonicClone7
  a smodule:ModulePortDatatype ; 
  smodule:variableName "?mnemonicClone7" ;
  rdfs:domain xsd:string ;
  smodule:example "A4_HUMAN", "1433E_MOUSE", "1FEH2_WHEAT" ;
  rdfs:label "Mnemonic" ;
  smodule:isSelected "true"^^xsd:boolean.
	
up_mod:M57_module_port-oldmnemonicClone7 
  a smodule:ModulePortDatatype ;
  smodule:variableName "?oldmnemonicClone7" ;
  rdfs:domain xsd:string ;
  rdfs:label "Old mnemonic" ;
  smodule:isSelected "true"^^xsd:boolean.
