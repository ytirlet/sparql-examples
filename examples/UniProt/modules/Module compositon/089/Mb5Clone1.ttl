@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://base_module.biographs.org/Mb5_moduleClone1> a smodule:SPARQLModule ;
    rdfs:label "subject predicate object" ;
    smodule:clonedFrom <http://base_module.biographs.org/Mb5_module> ;
    smodule:fragmentSPARQL """ 
    ?subjectClone1 ?predicateClone1 ?objectClone1 .
    """ ;
    smodule:output <http://base_module.biographs.org/Mb5_module_port-predicateClone1>,
        <http://base_module.biographs.org/Mb5_module_port-subjectClone1>, <http://base_module.biographs.org/Mb5_module_port-objectClone1> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

""" .

<http://base_module.biographs.org/Mb5_module_port-predicateClone1> a smodule:ModulePortURI ;
    rdfs:label "Predicate" ;
    rdfs:domain rdf:Property ;
    smodule:isSelected true ;
    smodule:variableName "?predicateClone1" .

<http://base_module.biographs.org/Mb5_module_port-subjectClone1> a smodule:ModulePortURI ;
    rdfs:label "Subject" ;
    rdfs:domain rdfs:Resource ;
    smodule:isSelected false ;
    smodule:variableName "?subjectClone1" .

<http://base_module.biographs.org/Mb5_module_port-objectClone1> a smodule:ModulePortTyped ;
    rdfs:label "Object" ;
    rdfs:domain rdfs:Resource ;
    smodule:isSelected true ;
    smodule:variableName "?objectClone1" .
