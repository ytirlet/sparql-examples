@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M17_moduleClone27> a smodule:SPARQLModule ;
    rdfs:label "Protein information" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M17_module> ;
    smodule:fragmentSPARQL """
    ?proteinClone27 rdf:type up:Protein ;
      up:created ?creationDateClone27 ;
      up:modified ?modificationDateClone27 ;
      up:reviewed ?reviewedClone27 ;
      up:version ?versionClone27 .
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M17_module_port-creationDateClone27>,
        <http://uniprot_module.biographs.org/M17_module_port-modificationDateClone27>,
        <http://uniprot_module.biographs.org/M17_module_port-proteinClone27>,
        <http://uniprot_module.biographs.org/M17_module_port-reviewedClone27>,
        <http://uniprot_module.biographs.org/M17_module_port-versionClone27> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M17_module_port-creationDateClone27> a smodule:ModulePortURI ;
    rdfs:label "date of creation" ;
    rdfs:domain xsd:date ;
    smodule:isSelected true ;
    smodule:variableName "?creationDateClone27" .

<http://uniprot_module.biographs.org/M17_module_port-modificationDateClone27> a smodule:ModulePortDatatype ;
    rdfs:label "date of modification" ;
    rdfs:domain xsd:date ;
    smodule:isSelected true ;
    smodule:variableName "?modificationDateClone27" .

<http://uniprot_module.biographs.org/M17_module_port-proteinClone27> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:Protein ;
    smodule:isSelected true ;
    smodule:variableName "?proteinClone27" .

<http://uniprot_module.biographs.org/M17_module_port-reviewedClone27> a smodule:ModulePortDatatype ;
    rdfs:label "is reviewed" ;
    rdfs:domain xsd:boolean ;
    smodule:isSelected true ;
    smodule:variableName "?reviewedClone27" .

<http://uniprot_module.biographs.org/M17_module_port-versionClone27> a smodule:ModulePortDatatype ;
    rdfs:label "Version" ;
    rdfs:domain xsd:int ;
    smodule:isSelected true ;
    smodule:variableName "?versionClone27" .

