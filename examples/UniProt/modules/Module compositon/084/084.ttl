smodule:module_composition_084 rdf:type smodule:SPARQL_Module_Composition.
smodule:module_composition_084 smodule:hasConnection smodule:084_c1, smodule:084_c2, smodule:084_c3, smodule:084_c4, smodule:084_c5.
smodule:module_composition_084 smodule:hasComponent smodule:OperatorValuesClone115, smodule:OperatorValuesClone114, smodule:OperatorValuesClone113, up_mod:M74_moduleClone4, up_mod:M86_moduleClone1, up_mod:M86_moduleClone3.
smodule:module_composition_084 smodule:includeFile "VALUESClone115.ttl", "VALUESClone114.ttl", "VALUESClone113.ttl", "M74Clone4.ttl", "M86Clone1.ttl", "M86Clone3.ttl".

