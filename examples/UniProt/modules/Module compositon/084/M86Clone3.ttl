@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M86_moduleClone3> a smodule:SPARQLModule ;
    rdfs:label "Taxon rank" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M86_module> ;
    smodule:fragmentSPARQL """ 
    ?taxonClone3 up:rank ?rankClone3.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M86_module_port-rankClone3>,
        <http://uniprot_module.biographs.org/M86_module_port-taxonClone3> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M86_module_port-rankClone3> a smodule:ModulePortURI ;
    rdfs:label "Rank" ;
    rdfs:domain up:Rank ;
    smodule:isSelected false ;
    smodule:variableName "?rankClone3" .

<http://uniprot_module.biographs.org/M86_module_port-taxonClone3> a smodule:ModulePortURI ;
    rdfs:label "Taxon" ;
    rdfs:domain up:Taxon ;
    smodule:isSelected true ;
    smodule:variableName "?taxonClone3" .

