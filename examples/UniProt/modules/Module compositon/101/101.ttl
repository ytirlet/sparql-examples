smodule:module_composition_101 dcterms:title "List all human UniProtKB entries and their computationaly mapped potential isoforms.".
smodule:module_composition_101 rdfs:comment "List all human UniProtKB entries and their computationaly mapped potential isoforms.".
smodule:module_composition_101 dcterms:subject "isoform", "list".

smodule:module_composition_101 rdf:type smodule:SPARQL_Module_Composition.
smodule:module_composition_101 smodule:hasConnection smodule:101_c1 , smodule:101_c2.
smodule:module_composition_101 smodule:hasComponent smodule:OperatorValuesClone125, up_mod:M91_moduleClone1, up_mod:M67_moduleClone28.
smodule:module_composition_101 smodule:includeFile "VALUESClone125.ttl", "M91Clone1.ttl", "M67Clone28.ttl".

smodule:101_c1 rdf:type smodule:Connection.
smodule:101_c1 smodule:connects up_mod:M67_module_port-entryClone28, up_mod:M91_module_port-proteinClone1.

smodule:101_c2 rdf:type smodule:Connection.
smodule:101_c2 smodule:connects up_mod:M67_module_port-organismClone28, smodule:OperatorValuesPortResultClone125.

smodule:OperatorValuesPortResultClone125 smodule:valuesEnumeration "taxon:9606" .
