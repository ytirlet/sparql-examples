@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M39_moduleClone19> a smodule:SPARQLModule ;
    rdfs:label "Protein to catalyzed reaction" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M39_module> ;
    smodule:fragmentSPARQL """
    ?proteinClone19 rdf:type up:Protein .
    ?proteinClone19 up:annotation ?annotationClone19.
    ?annotationClone19 up:catalyticActivity ?catalyticActivityClone19.
    ?catalyticActivityClone19 rdf:type up:Catalytic_Activity .
    ?catalyticActivityClone19 up:catalyzedReaction ?reactionClone19.
    ?annotationClone19 rdf:type up:Catalytic_Activity_Annotation.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M39_module_port-annotationClone19>,
        <http://uniprot_module.biographs.org/M39_module_port-catalyticActivityClone19>,
        <http://uniprot_module.biographs.org/M39_module_port-proteinClone19>,
        <http://uniprot_module.biographs.org/M39_module_port-reactionClone19> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX : <http://biographs.org/>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M39_module_port-annotationClone19> a smodule:ModulePortURI ;
    rdfs:label "Annotation" ;
    rdfs:domain up:Catalytic_Activity_Annotation ;
    smodule:isSelected false ;
    smodule:variableName "?annotationClone19" .

<http://uniprot_module.biographs.org/M39_module_port-catalyticActivityClone19> a smodule:ModulePortURI ;
    rdfs:label "Catalytic Activity" ;
    rdfs:domain up:Catalytic_Activity ;
    smodule:isSelected false ;
    smodule:variableName "?catalyticActivityClone19" .

<http://uniprot_module.biographs.org/M39_module_port-proteinClone19> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:Protein ;
    smodule:isSelected true ;
    smodule:variableName "?proteinClone19" .

<http://uniprot_module.biographs.org/M39_module_port-reactionClone19> a smodule:ModulePortURI ;
    rdfs:label "Reaction" ;
    rdfs:domain <http://rdf.rhea-db.org/Reaction> ;
    smodule:isSelected false ;
    smodule:variableName "?reactionClone19" .

