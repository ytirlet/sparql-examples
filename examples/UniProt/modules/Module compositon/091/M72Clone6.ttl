@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

<http://uniprot_module.biographs.org/M72_moduleClone6> a smodule:SPARQLModule ;
    rdfs:label "Entry Names" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M72_module> ;
    smodule:fragmentSPARQL """
    ?entryClone6 up:recommendedName ?recNameClone6.
    ?entryClone6 up:alternativeName ?altNameClone6.
    ?recNameClone6 up:fullName ?fullNameClone6.
    ?recNameClone6 up:shortName ?shortNameClone6.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M72_module_port-altNameClone6>,
        <http://uniprot_module.biographs.org/M72_module_port-fullNameClone6>,
        <http://uniprot_module.biographs.org/M72_module_port-recNameClone6>,
        <http://uniprot_module.biographs.org/M72_module_port-shortNameClone6>,
        up_mod:M72_module_port-entryClone6;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M72_module_port-altNameClone6> a smodule:ModulePortURI ;
    rdfs:label "Alternative Name" ;
    rdfs:domain up:Structured_Name ;
    smodule:isSelected true ;
    smodule:variableName "?altNameClone6" .

<http://uniprot_module.biographs.org/M72_module_port-fullNameClone6> a smodule:ModulePortURI ;
    rdfs:label "Full Name" ;
    rdfs:domain up:Structured_Name ;
    smodule:isSelected true ;
    smodule:variableName "?fullNameClone6" .

<http://uniprot_module.biographs.org/M72_module_port-recNameClone6> a smodule:ModulePortURI ;
    rdfs:label "Recommended Name" ;
    rdfs:domain up:Structured_Name ;
    smodule:isSelected true ;
    smodule:variableName "r?ecNameClone6" .

<http://uniprot_module.biographs.org/M72_module_port-shortNameClone6> a smodule:ModulePortURI ;
    rdfs:label "Short Name" ;
    rdfs:domain up:Structured_Name ;
    smodule:isSelected true ;
    smodule:variableName "?shortNameClone6" .

up_mod:M72_module_port-entryClone6
  a smodule:ModulePortURI;
  rdfs:domain [
		a owl:Class ;
		smodule:option (up:Protein up:Part)
		]; 
  smodule:variableName "?entryClone6" ;
  rdfs:label "Entry" ;
  smodule:isSelected "true"^^xsd:boolean.
