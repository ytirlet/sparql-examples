@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M84_moduleClone2> a smodule:SPARQLModule ;
    rdfs:label "Enzyme class" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M84_module> ;
    smodule:fragmentSPARQL """ 
    ?catalyticActivityClone2 up:enzymeClass ?ECClone2 .
    ?ECClone2 rdfs:subClassOf ?ancestorECClone2.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M84_module_port-ECClone2>,
        <http://uniprot_module.biographs.org/M84_module_port-ancestorECClone2>,
        <http://uniprot_module.biographs.org/M84_module_port-catalyticActivityClone2> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M84_module_port-ECClone2> a smodule:ModulePortURI ;
    rdfs:label "Enzyme" ;
    rdfs:domain up:Enzyme ;
    smodule:isSelected false ;
    smodule:variableName "?ECClone2" .

<http://uniprot_module.biographs.org/M84_module_port-ancestorECClone2> a smodule:ModulePortURI ;
    rdfs:label "ancestor Enzyme" ;
    rdfs:domain up:Enzyme ;
    smodule:isSelected false ;
    smodule:variableName "?ancestorECClone2" .

<http://uniprot_module.biographs.org/M84_module_port-catalyticActivityClone2> a smodule:ModulePortURI ;
    rdfs:label "Catalytic Activity" ;
    rdfs:domain up:CatalyticActivity ;
    smodule:isSelected false ;
    smodule:variableName "?catalyticActivityClone2" .

