@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M96_moduleClone1> a smodule:SPARQLModule ;
    rdfs:label "Database category" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M96_module> ;
    smodule:fragmentSPARQL """ 
    ?databaseClone1 a up:Database.
    ?databaseClone1 up:category ?categoryClone1 .
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M96_module_port-categoryClone1>,
        <http://uniprot_module.biographs.org/M96_module_port-databaseClone1> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M96_module_port-categoryClone1> a smodule:ModulePortDatatype ;
    rdfs:label "Category" ;
    rdfs:domain xsd:string ;
    smodule:isSelected false ;
    smodule:variableName "?categoryClone1" .

<http://uniprot_module.biographs.org/M96_module_port-databaseClone1> a smodule:ModulePortURI ;
    rdfs:label "Database" ;
    rdfs:domain up:Database ;
    smodule:isSelected false ;
    smodule:variableName "?databaseClone1" .

