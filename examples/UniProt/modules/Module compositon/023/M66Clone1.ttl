@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M66_moduleClone1> a smodule:SPARQLModule ;
    rdfs:label "GO classification of protein" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M66_module> ;
    smodule:fragmentSPARQL """
    ?proteinClone1 up:classifiedWith/rdfs:subClassOf* ?goClone1 .
    GRAPH <https://sparql.uniprot.org/go> {
      ?goClone1 a owl:Class .
    }
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M66_module_port-goClone1>,
        <http://uniprot_module.biographs.org/M66_module_port-proteinClone1> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M66_module_port-goClone1> a smodule:ModulePortURI ;
    rdfs:label "Go term" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?goClone1" .

<http://uniprot_module.biographs.org/M66_module_port-proteinClone1> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:Protein ;
    smodule:isSelected true ;
    smodule:variableName "?proteinClone1" .

