@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M17_moduleClone4> a smodule:SPARQLModule ;
    rdfs:label "Protein information" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M17_module> ;
    smodule:fragmentSPARQL """
    ?proteinClone4 rdf:type up:Protein ;
      up:created ?creationDateClone4 ;
      up:modified ?modificationDateClone4 ;
      up:reviewed ?reviewedClone4 ;
      up:version ?versionClone4 .
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M17_module_port-creationDateClone4>,
        <http://uniprot_module.biographs.org/M17_module_port-modificationDateClone4>,
        <http://uniprot_module.biographs.org/M17_module_port-proteinClone4>,
        <http://uniprot_module.biographs.org/M17_module_port-reviewedClone4>,
        <http://uniprot_module.biographs.org/M17_module_port-versionClone4> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M17_module_port-creationDateClone4> a smodule:ModulePortURI ;
    rdfs:label "date of creation" ;
    rdfs:domain xsd:date ;
    smodule:isSelected false ;
    smodule:variableName "?creationDateClone4" .

<http://uniprot_module.biographs.org/M17_module_port-modificationDateClone4> a smodule:ModulePortDatatype ;
    rdfs:label "date of modification" ;
    rdfs:domain xsd:date ;
    smodule:isSelected false ;
    smodule:variableName "?modificationDateClone4" .

<http://uniprot_module.biographs.org/M17_module_port-proteinClone4> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:Protein ;
    smodule:isSelected true ;
    smodule:variableName "?proteinClone4" .

<http://uniprot_module.biographs.org/M17_module_port-reviewedClone4> a smodule:ModulePortDatatype ;
    rdfs:label "is reviewed" ;
    rdfs:domain xsd:boolean ;
    smodule:isSelected false ;
    smodule:variableName "?reviewedClone4" .

<http://uniprot_module.biographs.org/M17_module_port-versionClone4> a smodule:ModulePortDatatype ;
    rdfs:label "Version" ;
    rdfs:domain xsd:int ;
    smodule:isSelected false ;
    smodule:variableName "?versionClone4" .

