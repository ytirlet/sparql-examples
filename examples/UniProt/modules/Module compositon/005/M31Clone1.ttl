@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M31_moduleClone1> a smodule:SPARQLModule ;
    rdfs:label "Entry and database" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M31_module> ;
    smodule:fragmentSPARQL """
    ?entryClone1 rdf:type ?entryTypeClone1.
    ?entryClone1 rdfs:seeAlso ?dbentryClone1.
    ?dbentryClone1 up:database ?databaseClone1.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M31_module_port-databaseClone1>,
        <http://uniprot_module.biographs.org/M31_module_port-dbentryClone1>,
        <http://uniprot_module.biographs.org/M31_module_port-entryClone1>,
        <http://uniprot_module.biographs.org/M31_module_port-entryTypeClone1> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M31_module_port-databaseClone1> a smodule:ModulePortURI ;
    rdfs:label "Database" ;
    rdfs:domain up:Database ;
    smodule:isSelected true ;
    smodule:variableName "?databaseClone1" .

<http://uniprot_module.biographs.org/M31_module_port-dbentryClone1> a smodule:ModulePortURI ;
    rdfs:label "Database entry" ;
    rdfs:domain up:Ressource ;
    smodule:isSelected false ;
    smodule:variableName "?dbentryClone1" .

<http://uniprot_module.biographs.org/M31_module_port-entryClone1> a smodule:ModulePortURI ;
    rdfs:label "Entry" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected true ;
    smodule:variableName "?entryClone1" .

<http://uniprot_module.biographs.org/M31_module_port-entryTypeClone1> a smodule:ModulePortURI ;
    rdfs:label "Entry type" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?entryTypeClone1" .

