@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M77_moduleClone3> a smodule:SPARQLModule ;
    rdfs:label "Protein to proteome" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M77_module> ;
    smodule:fragmentSPARQL """
    ?proteinClone3 rdf:type up:Protein.
    ?proteinClone3 up:proteome ?proteomeClone3 .
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M77_module_port-proteinClone3>,
        <http://uniprot_module.biographs.org/M77_module_port-proteomeClone3> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M77_module_port-proteinClone3> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:Protein ;
    smodule:isSelected false ;
    smodule:variableName "?proteinClone3" .

<http://uniprot_module.biographs.org/M77_module_port-proteomeClone3> a smodule:ModulePortURI ;
    rdfs:label "Proteome" ;
    rdfs:domain up:Proteome_Component ;
    smodule:isSelected true ;
    smodule:variableName "?proteomeClone3" .

