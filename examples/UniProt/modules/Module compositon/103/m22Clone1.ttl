@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:m22_moduleClone1 a smodule:SPARQLModule;
  rdfs:label "englishLabelStr structured name"@en;
  rdfs:comment "englishLabelStr structured name"@en;
  smodule:clonedFrom <http://uniprot_module.biographs.org/m22_module> ;
  schema:keywords "structured name";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  """ ;
  smodule:fragmentSPARQL """
  BIND( strbefore( str(?proteomeDataClone1), '#' ) as ?proteomeClone1 )
  BIND( strafter( str(?proteomeDataClone1), '#' ) as ?repliconClone1 )
    """;
  smodule:output up_mod:m22_module_port-proteomeClone1, up_mod:m22_module_port-proteomeDataClone1, up_mod:m22_module_port-repliconClone1.
  
up_mod:m22_module_port-proteomeClone1
  a smodule:ModulePortURI;
  rdfs:domain up:Proteome_Component ;
  smodule:variableName "?proteomeClone1" ;
  rdfs:label "Proteome" ;
  smodule:isSelected "true"^^xsd:boolean.
  
up_mod:m22_module_port-proteomeDataClone1
  a smodule:ModulePortURI;
  rdfs:domain up:Proteome_Component ;
  smodule:variableName "?proteomeDataClone1" ;
  rdfs:label "proteome Data" ;
  smodule:isSelected "true"^^xsd:boolean.
  
up_mod:m22_module_port-repliconClone1
  a smodule:ModulePortURI;
  rdfs:domain up:Proteome_Component ;
  smodule:variableName "?repliconClone1" ;
  rdfs:label "replicon" ;
  smodule:isSelected "true"^^xsd:boolean.
