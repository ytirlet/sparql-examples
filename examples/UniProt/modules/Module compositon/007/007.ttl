@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

smodule:module_composition_007 dcterms:title "Select reviewed UniProtKB entries (Swiss-Prot), and their recommended protein name, that have a preferred gene name that contains the text 'DNA'".
smodule:module_composition_007 rdfs:comment "Select reviewed UniProtKB entries (Swiss-Prot), and their recommended protein name, that have a preferred gene name that contains the text 'DNA'".
smodule:module_composition_007 dcterms:subject "protein name", "gene name", "status".

smodule:module_composition_007 rdf:type smodule:SPARQL_Module_Composition.
smodule:module_composition_007 smodule:hasConnection smodule:007_c1, smodule:007_c2, smodule:007_c4 .
smodule:module_composition_007 smodule:hasComponent smodule:OperatorValuesClone7, up_mod:M73_moduleClone1, up_mod:M72_moduleClone1, up_mod:M17_moduleClone1.
smodule:module_composition_007 smodule:includeFile "VALUESClone7.ttl", "M73Clone1.ttl", "M72Clone1.ttl", "M17Clone1.ttl".

smodule:007_c1 rdf:type smodule:Connection.
smodule:007_c1 smodule:connects up_mod:M17_module_port-proteinClone1, up_mod:M72_module_port-entryClone1.

smodule:007_c2 rdf:type smodule:Connection.
smodule:007_c2 smodule:connects up_mod:M17_module_port-proteinClone1, up_mod:M73_module_port-proteinClone1.

#smodule:007_c3 rdf:type smodule:Connection.
#smodule:007_c3 smodule:connects up_mod:M73_module_port-nameClone1, smodule:OperatorFilterPortParameterClone14.

#smodule:OperatorFilterPortResultClone14 smodule:filterInput "CONTAINS(?result, 'DNA')" .

smodule:007_c4 rdf:type smodule:Connection.
smodule:007_c4 smodule:connects up_mod:M17_module_port-reviewedClone1, smodule:OperatorValuesPortResultClone7.

smodule:OperatorValuesPortResultClone7 smodule:valuesEnumeration "true" .
