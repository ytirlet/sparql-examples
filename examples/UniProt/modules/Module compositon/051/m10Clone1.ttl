@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/m10_moduleClone1> a smodule:SPARQLModule ;
    rdfs:label "englishLabelStr structured name" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/m10_module> ;
    smodule:fragmentSPARQL """ 
    ?subjectClone1 up:name ?nameClone1
    """ ;
    smodule:output <http://uniprot_module.biographs.org/m10_module_port-nameClone1>,
        <http://uniprot_module.biographs.org/m10_module_port-subjectClone1> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/m10_module_port-nameClone1> a smodule:ModulePortDatatype ;
    rdfs:label "Name" ;
    rdfs:domain xsd:string ;
    smodule:isSelected true ;
    smodule:variableName "?nameClone1" .

<http://uniprot_module.biographs.org/m10_module_port-subjectClone1> a smodule:ModulePortURI ;
    rdfs:label "Subject" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?subjectClone1" .

