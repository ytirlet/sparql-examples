@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/OperatorMinusClone1> a smodule:SPARQLModuleOperatorMinus ;
    rdfs:label "Operator MINUS" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/OperatorMinus> ;
    smodule:fragmentSPARQL """
  # minus Result variable is ?operatorMinusResult
  MINUS {
  [operatorParameter0]
  }
""" ;
    smodule:output <http://uniprot_module.biographs.org/OperatorMinusPortParameter0Clone1>,
        <http://uniprot_module.biographs.org/OperatorMinusPortResultClone1> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

""" .

<http://uniprot_module.biographs.org/OperatorMinusPortParameter0Clone1> a smodule:ModulePortOperatorParameter ;
    rdfs:label "Parameter0" ;
    smodule:isSelected false ;
    smodule:variableName "[operatorParameter0]" .

<http://uniprot_module.biographs.org/OperatorMinusPortResultClone1> a smodule:ModulePortTyped ;
    rdfs:label "Result" ;
    rdfs:domain xsd:any ;
    smodule:isSelected false ;
    smodule:variableName "?operatorMinusResult" .

