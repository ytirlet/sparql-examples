@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M82_moduleClone3> a smodule:SPARQLModule ;
    rdfs:label "Structured name type" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M82_module> ;
    smodule:fragmentSPARQL """ 
    ?structuredNameClone3 ?anyKindOfNameClone3  ?namesClone3 .
    ?anyKindOfNameClone3 rdfs:subPropertyOf up:structuredNameType .
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M82_module_port-anyKindOfNameClone3>,
        <http://uniprot_module.biographs.org/M82_module_port-namesClone3>,
        <http://uniprot_module.biographs.org/M82_module_port-structuredNameClone3> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M82_module_port-anyKindOfNameClone3> a smodule:ModulePortURI ;
    rdfs:label "Structured Name Type" ;
    rdfs:domain up:structuredNameType ;
    smodule:isSelected true ;
    smodule:variableName "?anyKindOfNameClone3" .

<http://uniprot_module.biographs.org/M82_module_port-namesClone3> a smodule:ModulePortDatatype ;
    rdfs:label "Other name" ;
    rdfs:domain xsd:string ;
    smodule:isSelected true ;
    smodule:variableName "?namesClone3" .

<http://uniprot_module.biographs.org/M82_module_port-structuredNameClone3> a smodule:ModulePortURI ;
    rdfs:label "Structured Name" ;
    rdfs:domain up:StructuredName ;
    smodule:isSelected false ;
    smodule:variableName "?structuredNameClone3" .

