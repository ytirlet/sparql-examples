@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://sparql_module.biographs.org/OperatorUnionClone15> a smodule:SPARQLModuleOperatorUnion ;
    rdfs:label "Operator UNION" ;
    smodule:clonedFrom <https://sparql_module.biographs.org/OperatorUnion> ;
    smodule:fragmentSPARQL """
  # union Result variable is ?operatorUnionResult
  {
  [operatorParameter0]
  }
  UNION {
  [operatorParameter1]
  }
""" ;
    smodule:output <https://sparql_module.biographs.org/OperatorUnionPortParameter0Clone15>,
        <https://sparql_module.biographs.org/OperatorUnionPortParameter1Clone15>,
        <https://sparql_module.biographs.org/OperatorUnionPortResultClone15> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

""" .

<https://sparql_module.biographs.org/OperatorUnionPortParameter0Clone15> a smodule:ModulePortOperatorParameter ;
    rdfs:label "Parameter0" ;
    smodule:isSelected false ;
    smodule:variableName "[operatorParameter0]" .

<https://sparql_module.biographs.org/OperatorUnionPortParameter1Clone15> a smodule:ModulePortOperatorParameter ;
    rdfs:label "Parameter1" ;
    smodule:isSelected false ;
    smodule:variableName "[operatorParameter1]" .

<https://sparql_module.biographs.org/OperatorUnionPortResultClone15> a smodule:ModulePortTyped ;
    rdfs:label "Result" ;
    rdfs:domain xsd:any ;
    smodule:isSelected false ;
    smodule:variableName "?operatorUnionResult" .

