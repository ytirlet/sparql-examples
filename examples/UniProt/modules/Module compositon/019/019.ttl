smodule:module_composition_019 dcterms:title "Find all natural variant annotations if associated via an evidence tag to an article with a PubMed identifier".
smodule:module_composition_019 rdfs:comment "Find all natural variant annotations if associated via an evidence tag to an article with a PubMed identifier".
smodule:module_composition_019 dcterms:subject "variant annotation", "evidence tag", "PubMed".

smodule:module_composition_019 rdf:type smodule:SPARQL_Module_Composition.
smodule:module_composition_019 smodule:hasConnection smodule:019_c1, smodule:019_c2, smodule:019_c3, smodule:019_c4, smodule:019_c5, smodule:019_c6 .
smodule:module_composition_019 smodule:hasComponent smodule:OperatorValuesClone21, smodule:OperatorValuesClone20, up_mod:M14_moduleClone4, up_mod:M20_moduleClone1, up_mod:m31_moduleClone1.
smodule:module_composition_019 smodule:includeFile "VALUESClone21.ttl", "VALUESClone20.ttl", "M14Clone4.ttl", "M20Clone1.ttl", "m31Clone1.ttl".

smodule:019_c1 rdf:type smodule:Connection.
