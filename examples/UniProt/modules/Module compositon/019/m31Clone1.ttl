@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:m31_moduleClone1 a smodule:SPARQLModule;
  rdfs:label "Database protein"@en;
  rdfs:comment "Database protein"@en;
  smodule:clonedFrom <http://uniprot_module.biographs.org/m31_module> ;
  schema:keywords "protein";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  """ ;
  smodule:fragmentSPARQL """ 
    BIND(SUBSTR(STR(?proteinClone1),33) AS ?accessionClone1)
  BIND(IF(CONTAINS(STR(?annotationClone1), "#SIP"), SUBSTR(STR(?annotationClone1),33), SUBSTR(STR(?annotationClone1),36))AS?annotation_accClone1)
  BIND(SUBSTR(STR(?sourceClone1),35) AS ?pubmedClone1)
    """;
  smodule:output up_mod:m31_module_port-annotationClone1, up_mod:m31_module_port-proteinClone1, up_mod:m31_module_port-sourceClone1.
  
up_mod:m31_module_port-proteinClone1
  a smodule:ModulePortURI;
  rdfs:domain up:Protein ;
  smodule:variableName "?proteinClone1" ;
  rdfs:label "protein" ;
  smodule:isSelected "true"^^xsd:boolean .

up_mod:m31_module_port-annotationClone1
  a smodule:ModulePortURI;
  rdfs:domain up:Annotation ;
  smodule:variableName "?annotationClone1" ;
  rdfs:label "annotation" ;
  smodule:isSelected "true"^^xsd:boolean .
  
up_mod:m31_module_port-sourceClone1
  a smodule:ModulePortURI;
  smodule:variableName "?sourceClone1" ;
  rdfs:label "source" ;
  smodule:isSelected "true"^^xsd:boolean .
