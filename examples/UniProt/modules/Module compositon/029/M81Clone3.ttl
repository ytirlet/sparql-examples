@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M81_moduleClone3> a smodule:SPARQLModule ;
    rdfs:label "Protein part" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M81_module> ;
    smodule:fragmentSPARQL """ 
    ?proteinClone3 rdf:type up:Protein.
    ?proteinClone3 up:domain|up:component ?partClone3.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M81_module_port-partClone3>,
        <http://uniprot_module.biographs.org/M81_module_port-proteinClone3> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M81_module_port-partClone3> a smodule:ModulePortURI ;
    rdfs:label "Protein part" ;
    rdfs:domain up:Part ;
    smodule:isSelected false ;
    smodule:variableName "?partClone3" .

<http://uniprot_module.biographs.org/M81_module_port-proteinClone3> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:Protein ;
    smodule:isSelected true ;
    smodule:variableName "?proteinClone3" .

