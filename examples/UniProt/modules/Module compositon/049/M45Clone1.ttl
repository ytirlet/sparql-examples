@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M45_moduleClone1> a smodule:SPARQLModule ;
    rdfs:label "protein transcribed from gene" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M45_module> ;
    smodule:fragmentSPARQL """
    ?proteinClone1 rdfs:seeAlso ?entryClone1.
    ?entryClone1 up:transcribedFrom ?geneClone1.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M45_module_port-entryClone1>,
        <http://uniprot_module.biographs.org/M45_module_port-geneClone1>,
        <http://uniprot_module.biographs.org/M45_module_port-proteinClone1> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M45_module_port-entryClone1> a smodule:ModulePortURI ;
    rdfs:label "see also entry" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?entryClone1" .

<http://uniprot_module.biographs.org/M45_module_port-geneClone1> a smodule:ModulePortURI ;
    rdfs:label "Gene" ;
    rdfs:domain up:Gene ;
    smodule:isSelected true ;
    smodule:variableName "?geneClone1" .

<http://uniprot_module.biographs.org/M45_module_port-proteinClone1> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:Protein ;
    smodule:isSelected true ;
    smodule:variableName "?proteinClone1" .

