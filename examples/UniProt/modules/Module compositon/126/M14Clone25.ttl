@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M14_moduleClone25> a smodule:SPARQLModule ;
    rdfs:label "Protein annotation" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M14_module> ;
    smodule:fragmentSPARQL """ 
    ?proteinClone25 rdf:type up:Protein.
    ?proteinClone25 up:annotation ?annotationClone25.
    ?annotationClone25 rdf:type ?annotationTypeClone25.
    ?annotationClone25 rdfs:comment ?commentClone25.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M14_module_port-annotationClone25>,
        <http://uniprot_module.biographs.org/M14_module_port-annotationTypeClone25>,
        <http://uniprot_module.biographs.org/M14_module_port-commentClone25>,
        <http://uniprot_module.biographs.org/M14_module_port-proteinClone25> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M14_module_port-annotationClone25> a smodule:ModulePortURI ;
    rdfs:label "Annotation" ;
    rdfs:domain up:Annotation ;
    smodule:isSelected false ;
    smodule:variableName "?annotationClone25" .

<http://uniprot_module.biographs.org/M14_module_port-annotationTypeClone25> a smodule:ModulePortURI ;
    rdfs:label "Type of annotation" ;
    rdfs:domain up:Annotation ;
    smodule:isSelected false ;
    smodule:variableName "?annotationTypeClone25" .

<http://uniprot_module.biographs.org/M14_module_port-commentClone25> a smodule:ModulePortDatatype ;
    rdfs:label "Annotation comment" ;
    rdfs:domain xsd:string ;
    smodule:isSelected false ;
    smodule:variableName "?commentClone25" .

<http://uniprot_module.biographs.org/M14_module_port-proteinClone25> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:Protein ;
    smodule:isSelected true ;
    smodule:variableName "?proteinClone25" .

