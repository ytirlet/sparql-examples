@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M74_moduleClone9> a smodule:SPARQLModule ;
    rdfs:label "Taxon, Scientific name and ancestor Class" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M74_module> ;
    smodule:fragmentSPARQL """
    ?taxonClone9 rdf:type up:Taxon.
    ?taxonClone9 up:scientificName ?nameClone9.
    ?taxonClone9 rdfs:subClassOf ?ancestorTaxonClone9.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M74_module_port-ancestorTaxonClone9>,
        <http://uniprot_module.biographs.org/M74_module_port-nameClone9>,
        <http://uniprot_module.biographs.org/M74_module_port-taxonClone9> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M74_module_port-ancestorTaxonClone9> a smodule:ModulePortURI ;
    rdfs:label "Ancestor taxon" ;
    rdfs:domain up:Taxon ;
    smodule:isSelected false ;
    smodule:variableName "?ancestorTaxonClone9" .

<http://uniprot_module.biographs.org/M74_module_port-nameClone9> a smodule:ModulePortDatatype ;
    rdfs:label "Taxon name" ;
    rdfs:domain xsd:string ;
    smodule:isSelected true ;
    smodule:variableName "?nameClone9" .

<http://uniprot_module.biographs.org/M74_module_port-taxonClone9> a smodule:ModulePortURI ;
    rdfs:label "Taxon" ;
    rdfs:domain up:Taxon ;
    smodule:isSelected true ;
    smodule:variableName "?taxonClone9" .

