@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M57_moduleClone3> a smodule:SPARQLModule ;
    rdfs:label "entry mnemonic" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M57_module> ;
    smodule:fragmentSPARQL """
    ?entryClone3 rdf:type ?typeClone3.
    ?entryClone3 up:mnemonic ?mnemonicClone3.
    OPTIONAL {?entryClone3 up:oldMnemonic ?oldmnemonicClone3.}
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M57_module_port-mnemonicClone3>,
        <http://uniprot_module.biographs.org/M57_module_port-oldmnemonicClone3>,
        <http://uniprot_module.biographs.org/M57_module_port-typeClone3>, <http://uniprot_module.biographs.org/M57_module_port-entryClone3> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M57_module_port-mnemonicClone3> a smodule:ModulePortDatatype ;
    rdfs:label "Mnemonic" ;
    rdfs:domain xsd:string ;
    smodule:isSelected true ;
    smodule:variableName "?mnemonicClone3" .

<http://uniprot_module.biographs.org/M57_module_port-oldmnemonicClone3> a smodule:ModulePortDatatype ;
    rdfs:label "Old mnemonic" ;
    rdfs:domain xsd:string ;
    smodule:isSelected false ;
    smodule:variableName "?oldmnemonicClone3" .

<http://uniprot_module.biographs.org/M57_module_port-typeClone3> a smodule:ModulePortURI ;
    rdfs:label "Entry type" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected true ;
    smodule:variableName "?typeClone3" .

<http://uniprot_module.biographs.org/M57_module_port-entryClone3> a smodule:ModulePortURI ;
    rdfs:label "Entry" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?entryClone3" .
