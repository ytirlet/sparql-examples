smodule:module_composition_054 dcterms:title "Proteins with binding sites for ligands similar to heme".
smodule:module_composition_054 rdfs:comment "Proteins with binding sites for ligands similar to heme".
smodule:module_composition_054 dcterms:subject "binding site", "chemical similarity", "idms", "sachem", "federated query".

smodule:module_composition_054 rdf:type smodule:SPARQL_Module_Composition.
smodule:module_composition_054 smodule:hasConnection smodule:054_c1 , smodule:054_c2, smodule:054_c3, smodule:054_c4, smodule:054_c5, smodule:054_c6, smodule:054_c7. #, smodule:054_c8.
