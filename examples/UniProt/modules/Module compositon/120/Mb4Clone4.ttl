@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix base_mod: <http://base_module.biographs.org/> .

<http://base_module.biographs.org/Mb4_moduleClone4> a smodule:SPARQLModule ;
    rdfs:label "rdf type" ;
    smodule:clonedFrom <http://base_module.biographs.org/Mb4_module> ;
    smodule:fragmentSPARQL """ 
    ?subjectClone4 rdf:type ?typeClone4 .
    """ ;
    smodule:output <http://base_module.biographs.org/Mb4_module_port-subjectClone4>, base_mod:Mb4_module_port-typeClone4;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

""" .

<http://base_module.biographs.org/Mb4_module_port-subjectClone4> a smodule:ModulePortURI ;
    rdfs:label "Subject" ;
    rdfs:domain rdfs:Resource ;
    smodule:isSelected true ;
    smodule:variableName "?subjectClone4" .
    
base_mod:Mb4_module_port-typeClone4
  a smodule:ModulePortURI;
  rdfs:domain rdfs:Class;
  smodule:variableName "?typeClone4" ;
  rdfs:label "Type" ;
  smodule:isSelected "false"^^xsd:boolean .

