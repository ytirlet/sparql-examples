@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/m11_moduleClone1> a smodule:SPARQLModule ;
    rdfs:label "englishLabelStr structured name" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/m11_module> ;
    smodule:fragmentSPARQL """ 
    SERVICE <https://idsm.elixir-czech.cz/sparql/endpoint/idsm> {
    ?activityClone1 a cco:Activity ;
      cco:hasMolecule ?chemblMoleculeClone1 ;
      cco:hasAssay ?assayClone1 ;
      cco:standardType ?activityTypeClone1 ;
      cco:standardValue ?standardActivityValueClone1 ;
      cco:standardUnits ?standardActivityUnitClone1 .
    ?chemblMoleculeClone1 cco:highestDevelopmentPhase ?highestDevelopmentPhaseClone1 ;
      rdfs:label ?chemblMoleculeLabelClone1 ;
      skos:prefLabel ?chemlbMoleculePrefLabelClone1 .
    FILTER (?highestDevelopmentPhaseClone1 > 3)
    ?assayClone1 cco:hasTarget ?targetClone1 .
    ?targetClone1 cco:hasTargetComponent/cco:targetCmptXref ?proteinClone1 .
    ?proteinClone1 a cco:UniprotRef .
  }
    """ ;
    smodule:output <http://uniprot_module.biographs.org/m11_module_port-proteinClone1> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

""" .

<http://uniprot_module.biographs.org/m11_module_port-proteinClone1> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain <http://purl.uniprot.org/core/Protein> ;
    smodule:isSelected true ;
    smodule:variableName "?proteinClone1" .

