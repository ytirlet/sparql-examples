@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .


<http://uniprot_module.biographs.org/M72_moduleClone4> a smodule:SPARQLModule ;
    rdfs:label "Entry Names" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M72_module> ;
    smodule:fragmentSPARQL """
    ?entryClone4 up:recommendedName ?recNameClone4.
    ?entryClone4 up:alternativeName ?altNameClone4.
    ?recNameClone4 up:fullName ?fullNameClone4.
    ?recNameClone4 up:shortName ?shortNameClone4.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M72_module_port-altNameClone4>,
        <http://uniprot_module.biographs.org/M72_module_port-fullNameClone4>,
        <http://uniprot_module.biographs.org/M72_module_port-recNameClone4>,
        <http://uniprot_module.biographs.org/M72_module_port-shortNameClone4>,
        up_mod:M72_module_port-entryClone4;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M72_module_port-altNameClone4> a smodule:ModulePortURI ;
    rdfs:label "Alternative Name" ;
    rdfs:domain up:Structured_Name ;
    smodule:isSelected false ;
    smodule:variableName "?altNameClone4" .

<http://uniprot_module.biographs.org/M72_module_port-fullNameClone4> a smodule:ModulePortURI ;
    rdfs:label "Full Name" ;
    rdfs:domain up:Structured_Name ;
    smodule:isSelected true ;
    smodule:variableName "?fullNameClone4" .

<http://uniprot_module.biographs.org/M72_module_port-recNameClone4> a smodule:ModulePortURI ;
    rdfs:label "Recommended Name" ;
    rdfs:domain up:Structured_Name ;
    smodule:isSelected false ;
    smodule:variableName "r?ecNameClone4" .

<http://uniprot_module.biographs.org/M72_module_port-shortNameClone4> a smodule:ModulePortURI ;
    rdfs:label "Short Name" ;
    rdfs:domain up:Structured_Name ;
    smodule:isSelected false ;
    smodule:variableName "?shortNameClone4" .
    
up_mod:M72_module_port-entryClone4
  a smodule:ModulePortURI;
  rdfs:domain [
		a owl:Class ;
		smodule:option (up:Protein up:Part)
		]; 
  smodule:variableName "?entryClone4" ;
  rdfs:label "Entry" ;
  smodule:isSelected "true"^^xsd:boolean.

