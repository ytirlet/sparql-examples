@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M76_moduleClone7> a smodule:SPARQLModule ;
    rdfs:label "faldo: start/end position and reference" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M76_module> ;
    smodule:fragmentSPARQL """
    ?entryClone7 faldo:begin ?faldoBeginClone7.
    ?faldoBeginClone7 faldo:position ?beginPositionClone7.
    ?faldoBeginClone7 faldo:reference ?referenceClone7.
    ?entryClone7 faldo:end ?faldoEndClone7.
    ?faldoEndClone7 faldo:position ?endPositionClone7.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M76_module_port-beginPositionClone7>,
        <http://uniprot_module.biographs.org/M76_module_port-endPositionClone7>,
        <http://uniprot_module.biographs.org/M76_module_port-entryClone7>,
        <http://uniprot_module.biographs.org/M76_module_port-faldoBeginClone7>,
        <http://uniprot_module.biographs.org/M76_module_port-faldoEndClone7>,
        <http://uniprot_module.biographs.org/M76_module_port-referenceClone7> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX faldo: <http://biohackathon.org/resource/faldo#>

""" .

<http://uniprot_module.biographs.org/M76_module_port-beginPositionClone7> a smodule:ModulePortURI ;
    rdfs:label "Begin Position" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?beginPositionClone7" .

<http://uniprot_module.biographs.org/M76_module_port-endPositionClone7> a smodule:ModulePortURI ;
    rdfs:label "End Position" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?endPositionClone7" .

<http://uniprot_module.biographs.org/M76_module_port-entryClone7> a smodule:ModulePortURI ;
    rdfs:label "Entry" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?entryClone7" .

<http://uniprot_module.biographs.org/M76_module_port-faldoBeginClone7> a smodule:ModulePortURI ;
    rdfs:label "FALDO begin" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?faldoBeginClone7" .

<http://uniprot_module.biographs.org/M76_module_port-faldoEndClone7> a smodule:ModulePortURI ;
    rdfs:label "FALDO end" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?faldoEndClone7" .

<http://uniprot_module.biographs.org/M76_module_port-referenceClone7> a smodule:ModulePortURI ;
    rdfs:label "Reference" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?referenceClone7" .

