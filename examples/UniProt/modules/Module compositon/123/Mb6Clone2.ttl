@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix base_mod: <http://base_module.biographs.org/> .

<http://base_module.biographs.org/Mb6_moduleClone2> a smodule:SPARQLModule ;
    rdfs:label "rdfs sub class of" ;
    smodule:clonedFrom <http://base_module.biographs.org/Mb6_module> ;
    smodule:fragmentSPARQL """ 
    ?subjectClone2 rdfs:subClassOf ?classClone2 .
    """ ;
    smodule:output <http://base_module.biographs.org/Mb6_module_port-subjectClone2>, <http://base_module.biographs.org/Mb6_module_port-classClone2> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

""" .

<http://base_module.biographs.org/Mb6_module_port-subjectClone2> a smodule:ModulePortURI ;
    rdfs:label "Subject" ;
    rdfs:domain rdfs:Resource ;
    smodule:isSelected true ;
    smodule:variableName "?subjectClone2" .
    
<http://base_module.biographs.org/Mb6_module_port-classClone2> a smodule:ModulePortURI ;
    rdfs:label "Class" ;
    rdfs:domain rdfs:Resource ;
    smodule:isSelected false ;
    smodule:variableName "?classClone2" .


