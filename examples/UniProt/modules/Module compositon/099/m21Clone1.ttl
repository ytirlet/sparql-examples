@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/m21_moduleClone1> a smodule:SPARQLModule ;
    rdfs:label "englishLabelStr structured name" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/m21_module> ;
    smodule:fragmentSPARQL """ 
    SERVICE <https://sparql.api.identifiers.org/sparql> {
        ?proteinClone1 owl:sameAs ?otherIdentifierClone1 .
    }
    """ ;
    smodule:output <http://uniprot_module.biographs.org/m21_module_port-proteinClone1>, <http://uniprot_module.biographs.org/m21_module_port-otherIdentifierClone1> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

""" .

<http://uniprot_module.biographs.org/m21_module_port-proteinClone1> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain <http://purl.uniprot.org/core/Protein> ;
    smodule:isSelected true ;
    smodule:variableName "?proteinClone1" .

<http://uniprot_module.biographs.org/m21_module_port-otherIdentifierClone1> a smodule:ModulePortURI ;
    rdfs:label "other Identifier" ;
    rdfs:domain <http://purl.uniprot.org/core/Protein> ;
    smodule:isSelected true ;
    smodule:variableName "?otherIdentifierClone1" .
