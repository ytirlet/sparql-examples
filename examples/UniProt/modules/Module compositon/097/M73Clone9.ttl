@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M73_moduleClone9> a smodule:SPARQLModule ;
    rdfs:label "protein to gene" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M73_module> ;
    smodule:fragmentSPARQL """
    ?proteinClone9 rdf:type up:Protein.
    ?proteinClone9 up:encodedBy ?geneClone9.
    ?geneClone9 skos:prefLabel ?nameClone9.
    OPTIONAL {?geneClone9 up:locusName ?locusNameClone9.}
    OPTIONAL {?geneClone9 skos:altLabel ?altLabelClone9.}
    OPTIONAL {?geneClone9 up:orfName ?orfNameClone9.}
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M73_module_port-altLabelClone9>,
        <http://uniprot_module.biographs.org/M73_module_port-geneClone9>,
        <http://uniprot_module.biographs.org/M73_module_port-locusNameClone9>,
        <http://uniprot_module.biographs.org/M73_module_port-orfNameClone9>,
        <http://uniprot_module.biographs.org/M73_module_port-proteinClone9> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M73_module_port-altLabelClone9> a smodule:ModulePortDatatype ;
    rdfs:label "Alternative label" ;
    rdfs:domain xsd:string ;
    smodule:isSelected true ;
    smodule:variableName "?altLabelClone9" .

<http://uniprot_module.biographs.org/M73_module_port-geneClone9> a smodule:ModulePortURI ;
    rdfs:label "Gene" ;
    rdfs:domain up:Gene ;
    smodule:isSelected true ;
    smodule:variableName "?geneClone9" .

<http://uniprot_module.biographs.org/M73_module_port-locusNameClone9> a smodule:ModulePortDatatype ;
    rdfs:label "Locus name" ;
    rdfs:domain xsd:string ;
    smodule:isSelected true ;
    smodule:variableName "?locusNameClone9" .

<http://uniprot_module.biographs.org/M73_module_port-orfNameClone9> a smodule:ModulePortDatatype ;
    rdfs:label "ORF name" ;
    rdfs:domain xsd:string ;
    smodule:isSelected true ;
    smodule:variableName "?orfNameClone9" .

<http://uniprot_module.biographs.org/M73_module_port-proteinClone9> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:Protein ;
    smodule:isSelected true ;
    smodule:variableName "?proteinClone9" .

