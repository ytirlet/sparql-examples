smodule:module_composition_022 dcterms:title "For two accession numbers (ACs) find the GO term labels and group them into GO process,function and component".
smodule:module_composition_022 rdfs:comment "For two accession numbers (ACs) find the GO term labels and group them into GO process,function and component".
smodule:module_composition_022 dcterms:subject "gene ontology", "identifier".

smodule:module_composition_022 rdf:type smodule:SPARQL_Module_Composition.
smodule:module_composition_022 smodule:hasConnection smodule:022_c1 , smodule:022_c2.
smodule:module_composition_022 smodule:hasComponent smodule:OperatorValuesClone25, smodule:OperatorValuesClone24, up_mod:M23_moduleClone2.
smodule:module_composition_022 smodule:includeFile "VALUESClone25.ttl", "VALUESClone24.ttl", "M23Clone2.ttl".

smodule:022_c1 rdf:type smodule:Connection.
smodule:022_c1 smodule:connects up_mod:M23_module_port-ancestorGOTermClone2, smodule:OperatorValuesPortResultClone25.

smodule:OperatorValuesPortResultClone25 smodule:valuesEnumeration "GO:0008150 GO:0005575 GO:0003674" .

smodule:022_c2 rdf:type smodule:Connection.
