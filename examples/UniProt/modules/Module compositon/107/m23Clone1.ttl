@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/m23_moduleClone1> a smodule:SPARQLModule ;
    rdfs:label "englishLabelStr structured name" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/m23_module> ;
    smodule:fragmentSPARQL """ 
    OPTIONAL {
       	?sequenceClone1 a up:Simple_Sequence .
        BIND(true AS ?likelyIsCanonical)
      }
      OPTIONAL {
       	FILTER(?likelyIsCanonical)
        ?sequenceClone1 a up:External_Sequence .
        BIND(true AS ?isComplicated)
      }
      BIND(IF(BOUND(?isComplicated), STRENDS(STR(?entry), STRBEFORE(SUBSTR(STR(?sequence), 34),'-')),?likelyIsCanonical) AS ?isCanonical)
    """ ;
    smodule:output <http://uniprot_module.biographs.org/m23_module_port-sequenceClone1>, <http://uniprot_module.biographs.org/m23_module_port-isCanonicalClone1> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/m23_module_port-sequenceClone1> a smodule:ModulePortURI ;
    rdfs:label "Sequence" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected true ;
    smodule:variableName "?sequenceClone1" .
    
<http://uniprot_module.biographs.org/m23_module_port-isCanonicalClone1> a smodule:ModulePortURI ;
    rdfs:label "is Canonical" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected true ;
    smodule:variableName "?isCanonicalClone1" .

