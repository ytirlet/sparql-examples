@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

up_mod:M29_moduleClone1 a smodule:SPARQLModule;
  rdfs:label "Cluster and similar protein"@en;
  rdfs:comment "Cluster and similar protein"@en;
  smodule:clonedFrom <http://uniprot_module.biographs.org/M29_module> ;
  schema:keywords "similar protein";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
    """ ;
  smodule:fragmentSPARQL """
    ?clusterClone1 up:member ?memberClone1.
    ?memberClone1 up:sequenceFor ?similarClone1.
    ?clusterClone1 up:identity ?identityClone1.
    """;
  smodule:output up_mod:M29_module_port-clusterClone1, up_mod:M29_module_port-memberClone1, up_mod:M29_module_port-similarClone1, up_mod:M29_module_port-identityClone1 .

up_mod:M29_module_port-clusterClone1
  a smodule:ModulePortURI;
  smodule:variableName "?clusterClone1" ;
  rdfs:domain xsd:anyURI ;
  rdfs:label "Cluster" ;
  smodule:isSelected "false"^^xsd:boolean.

up_mod:M29_module_port-similarClone1
  a smodule:ModulePortURI;
  smodule:variableName "?similarClone1" ;
  rdfs:domain xsd:anyURI ;
  rdfs:label "Similar protein" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M29_module_port-memberClone1
  a smodule:ModulePortURI;
  smodule:variableName "?memberClone1" ;
  rdfs:domain xsd:anyURI ;
  rdfs:label "Member" ;
  smodule:isSelected "true"^^xsd:boolean.
  
up_mod:M29_module_port-identityClone1
  a smodule:ModulePortDatatype;
  smodule:variableName "?identityClone1" ;
  rdfs:domain [
		a owl:Class ;
		smodule:option ("0.5" "0.9" "1.0")
		]; 
  rdfs:label "Cluster identity" ;
  smodule:isSelected "false"^^xsd:boolean .
