@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M20_moduleClone6> a smodule:SPARQLModule ;
    rdfs:label "Annotation attribution" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M20_module> ;
    smodule:fragmentSPARQL """
    ?objectClone6 rdf:object ?annotationClone6.
    ?objectClone6 up:attribution ?attributionClone6.
    ?attributionClone6 up:source ?sourceClone6.
    ?sourceClone6 rdf:type ?sourceTypeClone6.
    ?attributionClone6 up:evidence ?evidenceClone6.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M20_module_port-annotationClone6>,
        <http://uniprot_module.biographs.org/M20_module_port-attributionClone6>,
        <http://uniprot_module.biographs.org/M20_module_port-evidenceClone6>,
        <http://uniprot_module.biographs.org/M20_module_port-objectClone6>,
        <http://uniprot_module.biographs.org/M20_module_port-sourceClone6>,
        <http://uniprot_module.biographs.org/M20_module_port-sourceTypeClone6> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M20_module_port-annotationClone6> a smodule:ModulePortURI ;
    rdfs:label "Annotation" ;
    rdfs:domain up:Annotation ;
    smodule:isSelected false ;
    smodule:variableName "?annotationClone6" .

<http://uniprot_module.biographs.org/M20_module_port-attributionClone6> a smodule:ModulePortURI ;
    rdfs:label "Attribution" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?attributionClone6" .

<http://uniprot_module.biographs.org/M20_module_port-evidenceClone6> a smodule:ModulePortURI ;
    rdfs:label "Evidence" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected true ;
    smodule:variableName "?evidenceClone6" .

<http://uniprot_module.biographs.org/M20_module_port-objectClone6> a smodule:ModulePortURI ;
    rdfs:label "Object" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?objectClone6" .

<http://uniprot_module.biographs.org/M20_module_port-sourceClone6> a smodule:ModulePortURI ;
    rdfs:label "Source" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?sourceClone6" .

<http://uniprot_module.biographs.org/M20_module_port-sourceTypeClone6> a smodule:ModulePortURI ;
    rdfs:label "Source type" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?sourceTypeClone6" .

