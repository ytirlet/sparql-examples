smodule:module_composition_020 dcterms:title "Find how often an article in PubMed was used in an evidence tag in a human protein (ordered by most used to least)".
smodule:module_composition_020 rdfs:comment "Find how often an article in PubMed was used in an evidence tag in a human protein (ordered by most used to least)".
smodule:module_composition_020 dcterms:subject "publication", "evidence tag", "PubMed", "sorting", "count".

smodule:module_composition_020 rdf:type smodule:SPARQL_Module_Composition.
smodule:module_composition_020 smodule:hasConnection smodule:020_c1, smodule:020_c2, smodule:020_c3, smodule:020_c4. #, smodule:020_c5, smodule:020_c6, smodule:020_c7, smodule:020_c8.
smodule:module_composition_020 smodule:hasComponent smodule:OperatorValuesClone23, smodule:OperatorValuesClone22, up_mod:M67_moduleClone6, up_mod:M20_moduleClone2, up_mod:M14_moduleClone5. #smodule:OperatorGroupByClone17, smodule:OperatorCountClone12, smodule:OperatorOrderByDescClone10,
smodule:module_composition_020 smodule:includeFile "VALUESClone23.ttl", "VALUESClone22.ttl", "M67Clone6.ttl", "M20Clone2.ttl", "M14Clone5.ttl". #"GROUPBYClone17.ttl", "COUNTClone12.ttl", "ORDERBYDESCClone10.ttl",

