smodule:020_c2 smodule:connects up_mod:M14_module_port-proteinClone5, up_mod:M67_module_port-entryClone6.

smodule:020_c3 rdf:type smodule:Connection.
smodule:020_c3 smodule:connects up_mod:M67_module_port-organismClone6, smodule:OperatorValuesPortResultClone23.

smodule:OperatorValuesPortResultClone23 smodule:valuesEnumeration "taxon:9606" .

smodule:020_c4 rdf:type smodule:Connection.
smodule:020_c4 smodule:connects up_mod:M20_module_port-sourceTypeClone2, smodule:OperatorValuesPortResultClone22.

smodule:OperatorValuesPortResultClone22 smodule:valuesEnumeration "up:Journal_Citation" .

