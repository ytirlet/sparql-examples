@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M20_moduleClone2> a smodule:SPARQLModule ;
    rdfs:label "Annotation attribution" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M20_module> ;
    smodule:fragmentSPARQL """
    ?objectClone2 rdf:object ?annotationClone2.
    ?objectClone2 up:attribution ?attributionClone2.
    ?attributionClone2 up:source ?sourceClone2.
    ?sourceClone2 rdf:type ?sourceTypeClone2.
    ?attributionClone2 up:evidence ?evidenceClone2.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M20_module_port-annotationClone2>,
        <http://uniprot_module.biographs.org/M20_module_port-attributionClone2>,
        <http://uniprot_module.biographs.org/M20_module_port-evidenceClone2>,
        <http://uniprot_module.biographs.org/M20_module_port-objectClone2>,
        <http://uniprot_module.biographs.org/M20_module_port-sourceClone2>,
        <http://uniprot_module.biographs.org/M20_module_port-sourceTypeClone2> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M20_module_port-annotationClone2> a smodule:ModulePortURI ;
    rdfs:label "Annotation" ;
    rdfs:domain up:Annotation ;
    smodule:isSelected false ;
    smodule:variableName "?annotationClone2" .

<http://uniprot_module.biographs.org/M20_module_port-attributionClone2> a smodule:ModulePortURI ;
    rdfs:label "Attribution" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected true ;
    smodule:variableName "?attributionClone2" .

<http://uniprot_module.biographs.org/M20_module_port-evidenceClone2> a smodule:ModulePortURI ;
    rdfs:label "Evidence" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?evidenceClone2" .

<http://uniprot_module.biographs.org/M20_module_port-objectClone2> a smodule:ModulePortURI ;
    rdfs:label "Object" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?objectClone2" .

<http://uniprot_module.biographs.org/M20_module_port-sourceClone2> a smodule:ModulePortURI ;
    rdfs:label "Source" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected true ;
    smodule:variableName "?sourceClone2" .

<http://uniprot_module.biographs.org/M20_module_port-sourceTypeClone2> a smodule:ModulePortURI ;
    rdfs:label "Source type" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?sourceTypeClone2" .

