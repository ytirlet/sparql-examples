@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M83_moduleClone1> a smodule:SPARQLModule ;
    rdfs:label "Chain sequence mapping" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M83_module> ;
    smodule:fragmentSPARQL """ 
    ?pdbClone1 up:database <http://purl.uniprot.org/database/PDB> ;
       up:chainSequenceMapping ?mappingProteinClone1 .
    ?mappingProteinClone1 up:chain ?chainsPlusRangeClone1 .
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M83_module_port-chainsPlusRangeClone1>,
        <http://uniprot_module.biographs.org/M83_module_port-mappingProteinClone1>,
        <http://uniprot_module.biographs.org/M83_module_port-pdbClone1> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M83_module_port-chainsPlusRangeClone1> a smodule:ModulePortDatatype ;
    rdfs:label "Amino Acids chain" ;
    rdfs:domain xsd:string ;
    smodule:isSelected false ;
    smodule:variableName "?chainsPlusRangeClone1" .

<http://uniprot_module.biographs.org/M83_module_port-mappingProteinClone1> a smodule:ModulePortURI ;
    rdfs:label "Mapping Protein" ;
    rdfs:domain up:Protein ;
    smodule:isSelected true ;
    smodule:variableName "?mappingProteinClone1" .

<http://uniprot_module.biographs.org/M83_module_port-pdbClone1> a smodule:ModulePortURI ;
    rdfs:label "PDB entry" ;
    rdfs:domain up:Resource ;
    smodule:isSelected false ;
    smodule:variableName "?pdbClone1" .

