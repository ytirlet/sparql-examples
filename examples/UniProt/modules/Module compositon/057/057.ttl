smodule:module_composition_057 rdf:type smodule:SPARQL_Module_Composition.
smodule:module_composition_057 smodule:hasConnection smodule:057_c1 , smodule:057_c2, smodule:057_c3, smodule:057_c4.
smodule:module_composition_057 smodule:hasComponent smodule:OperatorValuesClone76, up_mod:M83_moduleClone1, up_mod:M31_moduleClone7, up_mod:m14_moduleClone1.
