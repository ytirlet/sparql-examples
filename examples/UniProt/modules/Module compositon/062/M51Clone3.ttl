@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M51_moduleClone3> a smodule:SPARQLModule ;
    rdfs:label "protein and associated disease" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M51_module> ;
    smodule:fragmentSPARQL """
    ?proteinClone3 up:annotation ?annotationClone3.
    ?proteinClone3 rdf:type up:Protein.
    ?annotationClone3 rdf:type up:Disease_Annotation.
    ?annotationClone3 up:disease ?diseaseClone3.
    ?diseaseClone3 skos:prefLabel ?diseaseLabelClone3.
    ?diseaseClone3 rdf:type up:Disease.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M51_module_port-annotationClone3>,
        <http://uniprot_module.biographs.org/M51_module_port-diseaseClone3>,
        <http://uniprot_module.biographs.org/M51_module_port-diseaseLabelClone3>,
        <http://uniprot_module.biographs.org/M51_module_port-proteinClone3> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M51_module_port-annotationClone3> a smodule:ModulePortURI ;
    rdfs:label "Annotation" ;
    rdfs:domain up:Disease_Annotation ;
    smodule:isSelected false ;
    smodule:variableName "?annotationClone3" .

<http://uniprot_module.biographs.org/M51_module_port-diseaseClone3> a smodule:ModulePortURI ;
    rdfs:label "Disease" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected true ;
    smodule:variableName "?diseaseClone3" .

<http://uniprot_module.biographs.org/M51_module_port-diseaseLabelClone3> a smodule:ModulePortDatatype ;
    rdfs:label "Disease label" ;
    rdfs:domain xsd:string ;
    smodule:isSelected true ;
    smodule:variableName "?diseaseLabelClone3" .

<http://uniprot_module.biographs.org/M51_module_port-proteinClone3> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:Protein ;
    smodule:isSelected false ;
    smodule:variableName "?proteinClone3" .

