smodule:module_composition_062 rdf:type smodule:SPARQL_Module_Composition.
smodule:module_composition_062 smodule:hasConnection smodule:062_c1, smodule:062_c2, smodule:062_c3, smodule:062_c4 .
smodule:module_composition_062 smodule:hasComponent smodule:OperatorUnionClone10, up_mod:M83_moduleClone2, up_mod:M88_moduleClone2, up_mod:M51_moduleClone3, up_mod:M39_moduleClone12.
smodule:module_composition_062 smodule:includeFile "UNIONClone10.ttl", "M83Clone2.ttl", "M88Clone2.ttl", "M51Clone3.ttl", "M39Clone12.ttl".

