@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M88_moduleClone2> a smodule:SPARQLModule ;
    rdfs:label "Protein to enzyme" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M88_module> ;
    smodule:fragmentSPARQL """ 
    ?proteinClone2 up:enzyme ?enzymeClone2 .
    ?enzymeClone2 rdfs:subClassOf? ?ecClassClone2.
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M88_module_port-ecClassClone2>,
        <http://uniprot_module.biographs.org/M88_module_port-enzymeClone2>,
        <http://uniprot_module.biographs.org/M88_module_port-proteinClone2> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M88_module_port-ecClassClone2> a smodule:ModulePortURI ;
    rdfs:label "Enzyme Class" ;
    rdfs:domain up:Enzyme ;
    smodule:isSelected false ;
    smodule:variableName "?ecClassClone2" .

<http://uniprot_module.biographs.org/M88_module_port-enzymeClone2> a smodule:ModulePortURI ;
    rdfs:label "Enzyme" ;
    rdfs:domain up:Enzyme ;
    smodule:isSelected false ;
    smodule:variableName "?enzymeClone2" .

<http://uniprot_module.biographs.org/M88_module_port-proteinClone2> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:protein ;
    smodule:isSelected false ;
    smodule:variableName "?proteinClone2" .

