@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

<http://uniprot_module.biographs.org/M67_moduleClone2> a smodule:SPARQLModule ;
    rdfs:label "Entry to taxon" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M67_module> ;
    smodule:fragmentSPARQL """
    ?entryClone2 up:organism ?organismClone2.
    ?organismClone2 rdfs:subClassOf? ?taxonClone2. # Hierarchy of taxon is materialized
    """ ;
    smodule:output up_mod:M67_module_port-taxonClone2, up_mod:M67_module_port-entryClone2, up_mod:M67_module_port-organismClone2 ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>
""" .

up_mod:M67_module_port-taxonClone2 a smodule:ModulePortTyped ;
    rdfs:label "taxon" ;
    rdfs:domain xsd:any ;
    smodule:isSelected false ;
    smodule:variableName "?taxonClone2" .

up_mod:M67_module_port-organismClone2 a smodule:ModulePortTyped ;
    rdfs:label "organism" ;
    rdfs:domain xsd:any ;
    smodule:isSelected false ;
    smodule:variableName "?organismClone2" .

up_mod:M67_module_port-entryClone2 a smodule:ModulePortTyped ;
    rdfs:label "entry" ;
    rdfs:domain xsd:any ;
    smodule:isSelected false ;
    smodule:variableName "?entryClone2" .

