@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M73_moduleClone2> a smodule:SPARQLModule ;
    rdfs:label "protein to gene" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M73_module> ;
    smodule:fragmentSPARQL """
    ?proteinClone2 rdf:type up:Protein.
    ?proteinClone2 up:encodedBy ?geneClone2.
    ?geneClone2 skos:prefLabel ?nameClone2.
    OPTIONAL {?geneClone2 up:locusName ?locusNameClone2.}
    OPTIONAL {?geneClone2 skos:altLabel ?altLabelClone2.}
    OPTIONAL {?geneClone2 up:orfName ?orfNameClone2.}
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M73_module_port-altLabelClone2>,
        <http://uniprot_module.biographs.org/M73_module_port-geneClone2>,
        <http://uniprot_module.biographs.org/M73_module_port-nameClone2>,
        <http://uniprot_module.biographs.org/M73_module_port-locusNameClone2>,
        <http://uniprot_module.biographs.org/M73_module_port-orfNameClone2>,
        <http://uniprot_module.biographs.org/M73_module_port-proteinClone2> ;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M73_module_port-altLabelClone2> a smodule:ModulePortDatatype ;
    rdfs:label "Alternative label" ;
    rdfs:domain xsd:string ;
    smodule:isSelected false ;
    smodule:variableName "?altLabelClone2" .
    
<http://uniprot_module.biographs.org/M73_module_port-nameClone2> a smodule:ModulePortDatatype ;
    rdfs:label "Name" ;
    rdfs:domain xsd:string ;
    smodule:isSelected true ;
    smodule:variableName "?nameClone2" .

<http://uniprot_module.biographs.org/M73_module_port-geneClone2> a smodule:ModulePortURI ;
    rdfs:label "Gene" ;
    rdfs:domain up:Gene ;
    smodule:isSelected false ;
    smodule:variableName "?geneClone2" .

<http://uniprot_module.biographs.org/M73_module_port-locusNameClone2> a smodule:ModulePortDatatype ;
    rdfs:label "Locus name" ;
    rdfs:domain xsd:string ;
    smodule:isSelected false ;
    smodule:variableName "?locusNameClone2" .

<http://uniprot_module.biographs.org/M73_module_port-orfNameClone2> a smodule:ModulePortDatatype ;
    rdfs:label "ORF name" ;
    rdfs:domain xsd:string ;
    smodule:isSelected false ;
    smodule:variableName "?orfNameClone2" .

<http://uniprot_module.biographs.org/M73_module_port-proteinClone2> a smodule:ModulePortURI ;
    rdfs:label "Protein" ;
    rdfs:domain up:Protein ;
    smodule:isSelected false ;
    smodule:variableName "?proteinClone2" .

