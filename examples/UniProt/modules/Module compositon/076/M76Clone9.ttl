@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix faldo: <http://biohackathon.org/resource/faldo#> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:M76_moduleClone9 a smodule:SPARQLModule;
  rdfs:label "faldo: start/end position and reference"@en;
  rdfs:comment "faldo: start/end position and reference"@en;
  smodule:clonedFrom <http://uniprot_module.biographs.org/M76_module> ;
  schema:keywords "faldo begin", "faldo position", "falso reference";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
    PREFIX faldo: <http://biohackathon.org/resource/faldo#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
    """ ;
  smodule:fragmentSPARQL """
    ?entryClone9 faldo:begin ?faldoBeginClone9.
    ?faldoBeginClone9 faldo:position ?beginPositionClone9.
    ?faldoBeginClone9 faldo:reference ?referenceClone9.
    ?entryClone9 faldo:end ?faldoEndClone9.
    ?faldoEndClone9 faldo:position ?endPositionClone9.
    """;
  smodule:output up_mod:M76_module_port-entryClone9, up_mod:M76_module_port-faldoBeginClone9, up_mod:M76_module_port-faldoEndClone9, up_mod:M76_module_port-beginPositionClone9, up_mod:M76_module_port-endPositionClone9, up_mod:M76_module_port-referenceClone9 .

up_mod:M76_module_port-entryClone9
  a smodule:ModulePortURI;
  rdfs:domain xsd:anyURI ;
  smodule:variableName "?entryClone9" ;
  rdfs:label "Entry" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M76_module_port-referenceClone9
  a smodule:ModulePortURI;
  smodule:variableName "?referenceClone9" ;
  rdfs:label "Reference" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M76_module_port-endPositionClone9
  a smodule:ModulePortURI;
  smodule:variableName "?endPositionClone9" ;
  rdfs:label "End Position" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M76_module_port-faldoBeginClone9
  a smodule:ModulePortURI;
  smodule:variableName "?faldoBeginClone9" ;
  rdfs:label "FALDO begin" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M76_module_port-faldoEndClone9
  a smodule:ModulePortURI;
  smodule:variableName "?faldoEndClone9" ;
  rdfs:label "FALDO end" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M76_module_port-beginPositionClone9
  a smodule:ModulePortURI;
  smodule:variableName "?beginPositionClone9" ;
  rdfs:label "Begin Position" ;
  smodule:isSelected "true"^^xsd:boolean.
