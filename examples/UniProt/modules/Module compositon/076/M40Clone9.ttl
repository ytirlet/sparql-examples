@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:M40_moduleClone9 a smodule:SPARQLModule;
  rdfs:label "Protein to annotation range"@en;
  rdfs:comment "Protein to annotation range"@en;
  smodule:clonedFrom <http://uniprot_module.biographs.org/M40_module> ;
  schema:keywords "protein annotation", "annotation range";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
    """ ;
  smodule:fragmentSPARQL """
    ?proteinClone9 up:annotation ?annotationClone9.
    ?annotationClone9 up:range ?rangeClone9.
    """;
  smodule:output up_mod:M40_module_port-proteinClone9, up_mod:M40_module_port-annotationClone9, up_mod:M40_module_port-rangeClone9 .

up_mod:M40_module_port-annotationClone9
  a smodule:ModulePortURI;
  rdfs:domain up:Annotation ;
  smodule:variableName "?annotationClone9" ;
  rdfs:label "Annotation" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M40_module_port-proteinClone9
  a smodule:ModulePortURI;
  smodule:variableName "?proteinClone9" ;
  rdfs:domain up:Protein ;
  rdfs:label "Protein" ;
  smodule:isSelected "true"^^xsd:boolean.

up_mod:M40_module_port-rangeClone9
  a smodule:ModulePortURI;
  smodule:variableName "?rangeClone9" ;
  rdfs:label "Range" ;
  smodule:isSelected "true"^^xsd:boolean.
