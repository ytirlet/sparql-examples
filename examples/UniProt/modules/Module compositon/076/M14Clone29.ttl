@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix up: <http://purl.uniprot.org/core/> .
@prefix up_mod: <http://uniprot_module.biographs.org/> .

up_mod:M14_moduleClone29 a smodule:SPARQLModule;
  rdfs:label "Protein annotation"@en;
  rdfs:comment "Protein annotation"@en;
  smodule:clonedFrom <http://uniprot_module.biographs.org/M14_module> ;
  schema:keywords "annotation";
  smodule:prefixes """PREFIX up: <http://purl.uniprot.org/core/>
  PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
  PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
  """ ;
  smodule:fragmentSPARQL """ 
    ?proteinClone29 rdf:type up:ProteinClone29.
    ?proteinClone29 up:annotation ?annotationClone29.
    ?annotationClone29 rdf:type ?annotationTypeClone29.
    ?annotationClone29 rdfs:comment ?commentClone29.
    """;
  smodule:output up_mod:M14_module_port-proteinClone29, up_mod:M14_module_port-annotationClone29, up_mod:M14_module_port-annotationTypeClone29, up_mod:M14_module_port-commentClone29 .
  
up_mod:M14_module_port-annotationClone29
  a smodule:ModulePortURI;
  rdfs:domain up:Annotation ;
  smodule:variableName "?annotationClone29" ;
  rdfs:label "Annotation" ;
  smodule:isSelected "true"^^xsd:boolean .

up_mod:M14_module_port-proteinClone29
  a smodule:ModulePortURI;
  rdfs:domain up:Protein;
  smodule:variableName "?proteinClone29" ;
  rdfs:label "Protein" ;
  smodule:isSelected "true"^^xsd:boolean .

up_mod:M14_module_port-annotationTypeClone29
  a smodule:ModulePortURI;
  smodule:variableName "?annotationTypeClone29" ;
  rdfs:domain up:Annotation;
  rdfs:label "Type of annotation" ;
  smodule:isSelected "true"^^xsd:boolean .
  
up_mod:M14_module_port-commentClone29
  a smodule:ModulePortDatatype;
  rdfs:domain xsd:string ;
  smodule:variableName "?commentClone29" ;
  rdfs:label "Annotation comment" ;
  smodule:isSelected "true"^^xsd:boolean .
