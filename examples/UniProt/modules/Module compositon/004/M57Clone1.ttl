@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix smodule: <https://sparql_module.biographs.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://uniprot_module.biographs.org/M57_moduleClone1> a smodule:SPARQLModule ;
    rdfs:label "entry mnemonic" ;
    smodule:clonedFrom <http://uniprot_module.biographs.org/M57_module> ;
    smodule:fragmentSPARQL """
    ?entryClone1 rdf:type ?typeClone1.
    ?entryClone1 up:mnemonic ?mnemonicClone1.
    OPTIONAL {?entryClone1 up:oldMnemonic ?oldmnemonicClone1.}
    """ ;
    smodule:output <http://uniprot_module.biographs.org/M57_module_port-mnemonicClone1>,
        <http://uniprot_module.biographs.org/M57_module_port-oldmnemonicClone1>,
        <http://uniprot_module.biographs.org/M57_module_port-typeClone1> , <http://uniprot_module.biographs.org/M57_module_port-entryClone1>;
    smodule:prefixes """PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX up: <http://purl.uniprot.org/core/>

""" .

<http://uniprot_module.biographs.org/M57_module_port-mnemonicClone1> a smodule:ModulePortDatatype ;
    rdfs:label "Mnemonic" ;
    rdfs:domain xsd:string ;
    smodule:isSelected false ;
    smodule:variableName "?mnemonicClone1" .

<http://uniprot_module.biographs.org/M57_module_port-oldmnemonicClone1> a smodule:ModulePortDatatype ;
    rdfs:label "Old mnemonic" ;
    rdfs:domain xsd:string ;
    smodule:isSelected false ;
    smodule:variableName "?oldmnemonicClone1" .

<http://uniprot_module.biographs.org/M57_module_port-typeClone1> a smodule:ModulePortURI ;
    rdfs:label "Entry type" ;
    rdfs:domain xsd:anyURI ;
    smodule:isSelected false ;
    smodule:variableName "?typeClone1" .
    
<http://uniprot_module.biographs.org/M57_module_port-entryClone1> a smodule:ModulePortURI ;
    rdfs:label "Entry" ;
    rdfs:domain xsd:any ;
    smodule:isSelected true ;
    smodule:variableName "?entryClone1" .

