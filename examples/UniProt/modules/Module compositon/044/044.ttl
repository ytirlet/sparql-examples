smodule:module_composition_044 dcterms:title "Find the Rhea and InterPro combinations in UniProtKB entries.".
smodule:module_composition_044 rdfs:comment "Find the Rhea and InterPro combinations in UniProtKB entries.".
smodule:module_composition_044 dcterms:subject "enzyme", "domain", "InterPro", "Rhea".

smodule:module_composition_044 rdf:type smodule:SPARQL_Module_Composition.
smodule:module_composition_044 smodule:hasConnection smodule:044_c1 , smodule:044_c2, smodule:044_c3, smodule:044_c4. #, smodule:044_c5.
smodule:module_composition_044 smodule:hasComponent smodule:OperatorValuesClone54, smodule:OperatorValuesClone53, up_mod:M39_moduleClone3, up_mod:M31_moduleClone6, up_mod:M17_moduleClone7. #smodule:OperatorOrderByClone3, 
smodule:module_composition_044 smodule:includeFile "VALUESClone54.ttl", "VALUESClone53.ttl", "M39Clone3.ttl",  "M31Clone6.ttl",  "M17Clone7.ttl". # "ORDERBYClone3.ttl",

